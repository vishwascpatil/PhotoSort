<UserControl x:Class="PhotoSort.Views.VideoViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="Black"
             Focusable="True"
             Loaded="OnLoaded"
             Unloaded="OnUnloaded"
             PreviewKeyDown="OnPreviewKeyDown"
             PreviewMouseMove="OnRootPreviewMouseMove">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Layer 1: Video Player -->
        <MediaElement x:Name="VideoPlayer"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Stop"
                      Stretch="Uniform"
                      MediaOpened="OnMediaOpened"
                      MediaFailed="OnMediaFailed" />

        <!-- Layer 2: Poster Frame (overlays video until MediaOpened event) -->
        <Image x:Name="PosterImage"
               Source="{Binding PosterSource}"
               Stretch="Uniform"
               RenderOptions.BitmapScalingMode="HighQuality"
               Visibility="{Binding IsPosterVisible, Converter={StaticResource BoolToVisibilityConverter}}"
               IsHitTestVisible="False" />

        <!-- Layer 3: Overlay Controls (auto-hides after 3s of inactivity) -->
        <Grid x:Name="OverlayPanel" Opacity="1.0">
            <!-- Top bar: filename + close -->
            <Border VerticalAlignment="Top"
                    Height="52"
                    Background="#AA000000">
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Command="{Binding CloseCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Content="&#x2715;"
                            FontSize="18"
                            Foreground="White"
                            Cursor="Hand"
                            ToolTip="Close (Esc)" />

                    <TextBlock Grid.Column="1"
                               Text="{Binding FileName}"
                               Foreground="White"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="16,0,0,0"
                               TextTrimming="CharacterEllipsis" />
                </Grid>
            </Border>

            <!-- Center Play/Pause button -->
            <Border x:Name="PlayPauseButton"
                    Background="#88000000"
                    CornerRadius="48"
                    Width="96" Height="96"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Cursor="Hand"
                    MouseLeftButtonDown="OnPlayPauseClick">
                <TextBlock x:Name="PlayPauseIconText"
                           FontSize="40"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Text="&#x25B6;" />
            </Border>
        </Grid>

        <!-- Layer 4: Error Overlay -->
        <Border x:Name="ErrorOverlay"
                Background="#CC000000"
                Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        MaxWidth="500">
                <TextBlock Text="&#x26A0;"
                           FontSize="48"
                           Foreground="#FF6B6B"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16" />
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="White"
                           FontSize="16"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
                <Button Content="Retry"
                        Margin="0,24,0,0"
                        Padding="20,8"
                        HorizontalAlignment="Center"
                        Cursor="Hand"
                        Command="{Binding RetryCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#444444" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="FontSize" Value="14" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#666666" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Close"
                        Margin="0,8,0,0"
                        Padding="20,8"
                        HorizontalAlignment="Center"
                        Cursor="Hand"
                        Command="{Binding CloseCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="#CCCCCC" />
                            <Setter Property="BorderBrush" Value="#666666" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="FontSize" Value="13" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#444444" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
