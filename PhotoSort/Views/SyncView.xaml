<UserControl x:Class="PhotoSort.Views.SyncView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             Background="{DynamicResource WindowBackground}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══════════════ Header ═══════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource GalleryStatusBarBorder}"
                BorderThickness="0,0,0,1"
                Padding="32,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="44" Height="44"
                            CornerRadius="22"
                            Background="{DynamicResource PrimaryButtonBackground}"
                            VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="&#x1F504;"
                                   FontSize="22"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Library Sync"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TitleTextBrush}" />
                        <TextBlock Text="{Binding LastSyncDisplay, StringFormat='Last scan: {0}'}"
                                   FontSize="12"
                                   Foreground="{DynamicResource GalleryStatusText}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{DynamicResource CardBackground}"
                            CornerRadius="8"
                            BorderBrush="{DynamicResource GalleryStatusBarBorder}"
                            BorderThickness="1"
                            Padding="12,8"
                            Margin="0,0,12,0"
                            Visibility="{Binding IsWatching, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8"
                                     Fill="#4CAF50"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0" />
                            <TextBlock Text="{Binding CurrentProgress.ActiveWatcherCount, StringFormat={}{0} watchers active}"
                                       FontSize="12"
                                       Foreground="{DynamicResource GalleryMetricText}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Button Command="{Binding StartWatchingCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="16,8"
                            FontSize="12"
                            Visibility="{Binding IsWatching, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                            Margin="0,0,8,0"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8"
                                     Fill="#757575"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0" />
                            <TextBlock Text="Enable Watcher" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding StopWatchingCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="16,8"
                            FontSize="12"
                            Visibility="{Binding IsWatching, Converter={StaticResource BoolToVisibilityConverter}}"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8"
                                     Fill="#4CAF50"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0" />
                            <TextBlock Text="Watcher On" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════ Main Content ═══════════════ -->
        <ScrollViewer Grid.Row="1"
                       VerticalScrollBarVisibility="Auto"
                       HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,24,32,32">

                <!-- ═══ Library Overview Stats ═══ -->
                <Grid Margin="0,0,0,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource CardBorder}"
                            Margin="0,0,8,0"
                            Padding="20,16">
                        <StackPanel>
                            <TextBlock Text="&#x1F4F7;" FontSize="24" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding CurrentProgress.TotalProcessed, Mode=OneWay}"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource TitleTextBrush}" />
                            <TextBlock Text="Total Photos"
                                       FontSize="12"
                                       Foreground="{DynamicResource GalleryStatusText}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource CardBorder}"
                            Margin="8,0"
                            Padding="20,16">
                        <StackPanel>
                            <TextBlock Text="&#x1F465;" FontSize="24" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding FilesAddedCount}"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="#4CAF50" />
                            <TextBlock Text="New Photos"
                                       FontSize="12"
                                       Foreground="{DynamicResource GalleryStatusText}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource CardBorder}"
                            Margin="8,0"
                            Padding="20,16">
                        <StackPanel>
                            <TextBlock Text="&#x1F4C1;" FontSize="24" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding CurrentProgress.ActiveWatcherCount, Mode=OneWay}"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource TitleTextBrush}" />
                            <TextBlock Text="Watched Folders"
                                       FontSize="12"
                                       Foreground="{DynamicResource GalleryStatusText}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3"
                            Style="{StaticResource CardBorder}"
                            Margin="8,0,0,0"
                            Padding="20,16">
                        <StackPanel>
                            <TextBlock Text="&#x23F1;" FontSize="24" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding ElapsedDisplay, Mode=OneWay, TargetNullValue='--'}"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource TitleTextBrush}" />
                            <TextBlock Text="Last Sync"
                                       FontSize="12"
                                       Foreground="{DynamicResource GalleryStatusText}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ═══ Idle State: Hero CTA ═══ -->
                <Border Style="{StaticResource CardBorder}"
                        Padding="48,40"
                        Margin="0,0,0,20"
                        Visibility="{Binding IsSynchronizing, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Width="80" Height="80"
                                CornerRadius="40"
                                Background="{DynamicResource PrimaryButtonBackground}"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,20"
                                Opacity="0.15">
                            <TextBlock Text="&#x1F504;"
                                       FontSize="40"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Keep Your Library in Sync"
                                   FontSize="22" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TitleTextBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Scan your folders for new, modified, or removed photos and keep your library up to date."
                                   FontSize="14"
                                   Foreground="{DynamicResource GalleryStatusText}"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,24"
                                   MaxWidth="500"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center" />

                        <Button Command="{Binding SyncAllCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Padding="40,14"
                                FontSize="15"
                                HorizontalAlignment="Center"
                                Effect="{StaticResource CardHoverShadow}"
                                Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F50D;" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center" />
                                <TextBlock Text="Scan Library for Changes" FontSize="15" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- ═══ Sync Progress ═══ -->
                <Border Style="{StaticResource CardBorder}"
                        Padding="32,28"
                        Margin="0,0,0,20"
                        Visibility="{Binding IsSynchronizing, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="14" Height="14" CornerRadius="7"
                                    Background="#4FC3F7"
                                    VerticalAlignment="Center"
                                    Margin="0,0,10,0">
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Border.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="1" To="0.3"
                                                                 Duration="0:0:1"
                                                                 AutoReverse="True" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                            </Border>
                            <TextBlock Text="{Binding CurrentProgress.PhaseDisplay}"
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TitleTextBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding CurrentProgress.CurrentOperation}"
                                       FontSize="13"
                                       Foreground="{DynamicResource GalleryStatusText}"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0" />
                        </StackPanel>

                        <Border Background="{DynamicResource GallerySkeletonBrush}"
                                CornerRadius="6"
                                Height="10"
                                Margin="0,0,0,20">
                            <Border Background="{StaticResource PrimaryButtonBackground}"
                                    CornerRadius="6"
                                    HorizontalAlignment="Left"
                                    Width="{Binding CurrentProgress.ProgressPercent, Mode=OneWay}"
                                    Height="10" />
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="Added: "
                                           FontSize="13"
                                           Foreground="{DynamicResource GalleryStatusText}" />
                                <TextBlock Text="{Binding FilesAddedCount}"
                                           FontSize="13" FontWeight="Bold"
                                           Foreground="#4CAF50" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="Modified: "
                                           FontSize="13"
                                           Foreground="{DynamicResource GalleryStatusText}" />
                                <TextBlock Text="{Binding FilesModifiedCount}"
                                           FontSize="13" FontWeight="Bold"
                                           Foreground="{DynamicResource GalleryMetricText}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <TextBlock Text="Deleted: "
                                           FontSize="13"
                                           Foreground="{DynamicResource GalleryStatusText}" />
                                <TextBlock Text="{Binding FilesDeletedCount}"
                                           FontSize="13" FontWeight="Bold"
                                           Foreground="#EF5350" />
                            </StackPanel>

                            <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="16,0,0,0">
                                <Button Command="{Binding PauseSyncCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="16,6"
                                        FontSize="12"
                                        Visibility="{Binding IsPaused, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                        Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x23F8;" FontSize="11" Margin="0,0,6,0" />
                                        <TextBlock Text="Pause" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding ResumeSyncCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Padding="16,6"
                                        FontSize="12"
                                        Visibility="{Binding IsPaused, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x25B6;" FontSize="11" Margin="0,0,6,0" />
                                        <TextBlock Text="Resume" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding CancelSyncCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="16,6"
                                        FontSize="12">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x2715;" FontSize="11" Margin="0,0,6,0" />
                                        <TextBlock Text="Cancel" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ═══ Recent Activity ═══ -->
                <Border Style="{StaticResource CardBorder}"
                        Padding="24,20"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="&#x1F4CB;" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <TextBlock Text="Recent Activity"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TitleTextBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding RecentEvents.Count, StringFormat='({0} entries)'}"
                                       FontSize="12"
                                       Foreground="{DynamicResource GalleryStatusText}"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0" />
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding RecentEvents}"
                                      MaxHeight="280"
                                      Visibility="{Binding RecentEvents.Count, Converter={StaticResource NonZeroToVisibleConverter}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type sys:String}">
                                    <Border Margin="0,3"
                                            Padding="12,8"
                                            Background="{DynamicResource GalleryPlaceholderBackground}"
                                            CornerRadius="6">
                                        <TextBlock Text="{Binding}"
                                                   FontSize="12"
                                                   FontFamily="Consolas"
                                                   Foreground="{DynamicResource GalleryStatusText}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Margin="0,3"
                                Padding="12,28"
                                CornerRadius="6"
                                Visibility="{Binding RecentEvents.Count, Converter={StaticResource ZeroToVisibleConverter}}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="&#x1F4AD;"
                                           FontSize="32"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8"
                                           Opacity="0.4" />
                                <TextBlock Text="No recent activity"
                                           FontSize="13"
                                           Foreground="{DynamicResource GalleryStatusText}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Click 'Scan Library' above to start scanning for changes."
                                           FontSize="12"
                                           Foreground="{DynamicResource GalleryStatusText}"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0"
                                           Opacity="0.7" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ═══ Watched Folders ═══ -->
                <Border Style="{StaticResource CardBorder}"
                        Padding="24,20"
                        Margin="0,0,0,20"
                        Visibility="{Binding IsWatching, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="&#x1F4C2;" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <TextBlock Text="Watched Folders"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TitleTextBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding WatchedFolders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type sys:String}">
                                    <Border Margin="0,2"
                                            Padding="12,8"
                                            Background="{DynamicResource GalleryPlaceholderBackground}"
                                            CornerRadius="6">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#x1F4C1;" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource GalleryStatusText}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
