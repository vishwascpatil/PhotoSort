<UserControl x:Class="PhotoSort.Views.PhotoViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{DynamicResource ViewerBackground}"
             Focusable="True"
             Loaded="OnLoaded"
             Unloaded="OnUnloaded"
             PreviewKeyDown="OnPreviewKeyDown">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════ -->
        <!-- Main Viewer Area                            -->
        <!-- ═══════════════════════════════════════════ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ── Top Toolbar ── -->
            <Border Grid.Row="0"
                    Background="{DynamicResource ViewerToolbarBackground}"
                    BorderBrush="{DynamicResource ViewerToolbarBorder}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Close + Position -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Command="{Binding CloseCommand}"
                                Style="{StaticResource ViewerToolButton}"
                                ToolTip="Close (Esc)"
                                Margin="0,0,12,0">
                            <TextBlock Text="&#x2715;" FontSize="14" />
                        </Button>
                        <TextBlock Text="{Binding PositionText}"
                                   FontSize="13"
                                   Foreground="{DynamicResource ViewerTextBrush}"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold" />
                    </StackPanel>

                    <!-- Center: Zoom Controls -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Button Command="{Binding ZoomOutCommand}"
                                Style="{StaticResource ViewerToolButton}"
                                ToolTip="Zoom Out"
                                Margin="0,0,4,0">
                            <TextBlock Text="&#x2212;" FontSize="14" />
                        </Button>
                        <Border Background="{DynamicResource ViewerToolButtonBackground}"
                                CornerRadius="6"
                                Padding="12,4"
                                MinWidth="70"
                                HorizontalAlignment="Center">
                            <TextBlock Text="{Binding ZoomText}"
                                       FontSize="12"
                                       Foreground="{DynamicResource ViewerTextBrush}"
                                       HorizontalAlignment="Center"
                                       FontWeight="SemiBold" />
                        </Border>
                        <Button Command="{Binding ZoomInCommand}"
                                Style="{StaticResource ViewerToolButton}"
                                ToolTip="Zoom In"
                                Margin="4,0,0,0">
                            <TextBlock Text="&#x2B;" FontSize="14" />
                        </Button>
                    </StackPanel>

                    <!-- Right: Fit + Actual + Metadata Toggle -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Command="{Binding FitToScreenCommand}"
                                Style="{StaticResource ViewerToolButton}"
                                ToolTip="Fit to Screen (F)">
                            <TextBlock Text="Fit" FontSize="12" />
                        </Button>
                        <Button Command="{Binding ActualSizeCommand}"
                                Style="{StaticResource ViewerToolButton}"
                                ToolTip="Actual Size"
                                Margin="4,0,0,0">
                            <TextBlock Text="1:1" FontSize="12" />
                        </Button>
                        <Button Command="{Binding ToggleMetadataCommand}"
                                Style="{StaticResource ViewerToolButton}"
                                ToolTip="Toggle Metadata Panel"
                                Margin="12,0,0,0">
                            <TextBlock Text="&#x2194;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Content Area ── -->
            <Grid Grid.Row="1"
                  Background="{DynamicResource ViewerBackground}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Previous Arrow -->
                <Border Grid.Column="0"
                        Width="48"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        Cursor="Hand"
                        MouseLeftButtonDown="OnPreviousClick"
                        Visibility="{Binding HasPrevious, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="&#x276E;"
                               FontSize="24"
                               Foreground="{DynamicResource ViewerArrowBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <!-- Image / Video Display -->
                <Grid Grid.Column="1"
                      ClipToBounds="True"
                      MouseLeftButtonDown="OnContentMouseLeftButtonDown"
                      MouseLeftButtonUp="OnContentMouseLeftButtonUp"
                      MouseMove="OnContentMouseMove"
                      MouseWheel="OnContentMouseWheel">

                    <!-- Image Display -->
                    <Canvas x:Name="ImageCanvas"
                            Visibility="Visible">
                        <Canvas.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="ImageScaleTransform" />
                                <TranslateTransform x:Name="ImageTranslateTransform" />
                            </TransformGroup>
                        </Canvas.RenderTransform>
                        <Image x:Name="ViewerImage"
                               Source="{Binding CurrentImage}"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    </Canvas>

                    <!-- Video Display -->
                    <MediaElement x:Name="VideoPlayer"
                                  Visibility="{Binding IsVideo, Converter={StaticResource BoolToVisibilityConverter}}"
                                  LoadedBehavior="Manual"
                                  UnloadedBehavior="Stop"
                                  MediaOpened="OnMediaOpened"
                                  MediaFailed="OnMediaFailed"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  MaxWidth="1280" MaxHeight="720" />
                </Grid>

                <!-- Next Arrow -->
                <Border Grid.Column="2"
                        Width="48"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        Cursor="Hand"
                        MouseLeftButtonDown="OnNextClick"
                        Visibility="{Binding HasNext, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="&#x276F;"
                               FontSize="24"
                               Foreground="{DynamicResource ViewerArrowBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
            </Grid>

            <!-- ── Bottom Status Bar ── -->
            <Border Grid.Row="2"
                    Background="{DynamicResource ViewerToolbarBackground}"
                    BorderBrush="{DynamicResource ViewerToolbarBorder}"
                    BorderThickness="0,1,0,0"
                    Padding="16,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding CurrentPhoto.FileName, Mode=OneWay}"
                               FontSize="12"
                               Foreground="{DynamicResource ViewerStatusText}"
                               VerticalAlignment="Center" />

                    <TextBlock Grid.Column="2"
                               Text="{Binding CurrentPhoto.DisplaySize, Mode=OneWay, StringFormat='{}{0}'}"
                               FontSize="12"
                               Foreground="{DynamicResource ViewerStatusText}"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════ -->
        <!-- Metadata Panel                              -->
        <!-- ═══════════════════════════════════════════ -->
        <Border Grid.Column="1"
                Width="300"
                Background="{DynamicResource ViewerPanelBackground}"
                BorderBrush="{DynamicResource ViewerToolbarBorder}"
                BorderThickness="1,0,0,0"
                Visibility="{Binding IsMetadataVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="20,20,20,24">

                    <!-- Header -->
                    <TextBlock Text="Details"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ViewerTitleBrush}"
                               Margin="0,0,0,20" />

                    <!-- Date Taken -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="DATE TAKEN"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ViewerLabelBrush}"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="{Binding MetadataDateTaken}"
                                   FontSize="13"
                                   Foreground="{DynamicResource ViewerTextBrush}" />
                    </StackPanel>

                    <!-- File Name -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="FILE NAME"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ViewerLabelBrush}"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="{Binding MetadataFileName}"
                                   FontSize="13"
                                   Foreground="{DynamicResource ViewerTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- File Size -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="FILE SIZE"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ViewerLabelBrush}"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="{Binding MetadataFileSize}"
                                   FontSize="13"
                                   Foreground="{DynamicResource ViewerTextBrush}" />
                    </StackPanel>

                    <!-- Dimensions -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="DIMENSIONS"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ViewerLabelBrush}"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="{Binding MetadataDimensions}"
                                   FontSize="13"
                                   Foreground="{DynamicResource ViewerTextBrush}" />
                    </StackPanel>

                    <!-- Camera Make -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="CAMERA MAKE"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ViewerLabelBrush}"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="{Binding MetadataCameraMake}"
                                   FontSize="13"
                                   Foreground="{DynamicResource ViewerTextBrush}" />
                    </StackPanel>

                    <!-- Camera Model -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="CAMERA MODEL"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ViewerLabelBrush}"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="{Binding MetadataCameraModel}"
                                   FontSize="13"
                                   Foreground="{DynamicResource ViewerTextBrush}" />
                    </StackPanel>

                    <!-- Location -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="LOCATION"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ViewerLabelBrush}"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="{Binding MetadataLocation}"
                                   FontSize="13"
                                   Foreground="{DynamicResource ViewerTextBrush}" />
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
