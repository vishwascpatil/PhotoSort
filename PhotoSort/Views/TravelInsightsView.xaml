<UserControl x:Class="PhotoSort.Views.TravelInsightsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:PhotoSort.Models"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             Background="{DynamicResource WindowBackground}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource GalleryStatusBarBorder}"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="✈️" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBlock Text="Travel Insights" FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource TitleTextBrush}" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding DetectTripsCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="14,7" FontSize="12" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Detect Trips" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RefreshCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="14,7" FontSize="12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Refresh" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="0">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Loading Overlay -->
                <Border Grid.Row="0" Grid.RowSpan="8"
                        Background="#80000000"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                        Panel.ZIndex="100">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="40">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="✈️" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12" />
                                <TextBlock Text="{Binding StatusMessage}" FontSize="14"
                                           Foreground="{DynamicResource TitleTextBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 1. Overview Summary Cards -->
                <ItemsControl Grid.Row="0" ItemsSource="{Binding SummaryCards}" Margin="0,0,0,20">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:TravelSummaryCard}">
                            <Border Margin="4"
                                    Width="130"
                                    Padding="14,12"
                                    Background="{DynamicResource CardBackground}"
                                    CornerRadius="12"
                                    BorderBrush="{DynamicResource GalleryTileBorder}"
                                    BorderThickness="1">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Icon}" FontSize="22" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Value}" FontSize="20" FontWeight="Bold"
                                               Foreground="{DynamicResource GalleryMetricText}"
                                               HorizontalAlignment="Center" Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TitleTextBrush}"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Subtitle}" FontSize="10"
                                               Foreground="{DynamicResource GalleryStatusText}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 2. Travel Timeline (Years) -->
                <Border Grid.Row="1"
                        Background="{DynamicResource CardBackground}"
                        CornerRadius="12" Padding="20" Margin="0,0,0,20"
                        BorderBrush="{DynamicResource GalleryTileBorder}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="📅 Travel Timeline" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TitleTextBrush}" Margin="0,0,0,12" />

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding Years}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:TravelYear}">
                                    <Border Margin="0,0,0,8" Padding="14"
                                            Background="{DynamicResource GalleryPlaceholderBackground}"
                                            CornerRadius="8" Cursor="Hand"
                                            MouseLeftButtonDown="OnYearClick">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{Binding Year}"
                                                       FontSize="22" FontWeight="Bold"
                                                       Foreground="{DynamicResource GalleryMetricText}"
                                                       VerticalAlignment="Center" />

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                                <TextBlock Text="{Binding TripCount, Mode=OneWay, StringFormat='{}{0} trips  ·  {1} cities  ·  {2} countries'}"
                                                           FontSize="12" Foreground="{DynamicResource TitleTextBrush}"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding PhotoCount, Mode=OneWay, StringFormat='{}{0} photos  ·  {1:N0} km'}"
                                                           FontSize="11" Foreground="{DynamicResource GalleryStatusText}"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>

                                            <TextBlock Grid.Column="2" Text="▶" FontSize="12"
                                                       Foreground="{DynamicResource GalleryStatusText}"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- 3. Trip Cards -->
                <Border Grid.Row="2"
                        Background="{DynamicResource CardBackground}"
                        CornerRadius="12" Padding="20" Margin="0,0,0,20"
                        BorderBrush="{DynamicResource GalleryTileBorder}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="🗺️ Recent Trips" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TitleTextBrush}" Margin="0,0,0,12" />

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding RecentTrips}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:TripSummary}">
                                    <Border Margin="4"
                                            Width="240"
                                            Padding="0"
                                            Background="{DynamicResource GalleryPlaceholderBackground}"
                                            CornerRadius="12"
                                            BorderBrush="{DynamicResource GalleryTileBorder}"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="OnTripClick">
                                        <StackPanel>
                                            <!-- Cover Photo Area -->
                                            <Border Height="100" CornerRadius="12,12,0,0"
                                                    ClipToBounds="True"
                                                    Background="{DynamicResource GalleryPlaceholderBackground}">
                                                <Image Source="{Binding CoverPhotoPath, Converter={StaticResource ThumbnailToBitmapConverter}}"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       Stretch="UniformToFill"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                            </Border>

                                            <!-- Trip Info -->
                                            <Border Padding="12,10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TitleTextBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding DisplayDateRange}" FontSize="11"
                                                           Foreground="{DynamicResource GalleryStatusText}"
                                                           Margin="0,2,0,0" />
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                    <Border Background="{DynamicResource PrimaryButtonBackground}"
                                                            CornerRadius="4" Padding="6,2" Margin="0,0,4,0">
                                                        <TextBlock Text="{Binding PhotoCount, Mode=OneWay, StringFormat='{}{0} photos'}"
                                                                    FontSize="10" Foreground="White" FontWeight="SemiBold" />
                                                    </Border>
                                                    <Border Background="{DynamicResource GalleryTileBorder}"
                                                            CornerRadius="4" Padding="6,2">
                                                        <TextBlock Text="{Binding VideoCount, Mode=OneWay, StringFormat='{}{0} videos'}"
                                                                    FontSize="10" Foreground="{DynamicResource GalleryStatusText}"
                                                                    FontWeight="SemiBold" />
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding PlaceCount, Mode=OneWay, StringFormat='{}{0} places · {1:N0} km'}"
                                                           FontSize="10" Foreground="{DynamicResource GalleryStatusText}"
                                                           FontWeight="SemiBold" Margin="0,4,0,0" />
                                            </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- 4. Most Visited Places -->
                <Grid Grid.Row="3" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Top Countries -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource CardBackground}"
                            CornerRadius="12" Padding="20" Margin="0,0,10,0"
                            BorderBrush="{DynamicResource GalleryTileBorder}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="🌍 Top Countries" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TitleTextBrush}" Margin="0,0,0,10" />

                            <ItemsControl Grid.Row="1" ItemsSource="{Binding TopCountries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:TravelCountry}">
                                        <Border Margin="0,0,0,6" Padding="10"
                                                Background="{DynamicResource GalleryPlaceholderBackground}"
                                                CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Text="🌍" FontSize="16"
                                                           VerticalAlignment="Center" Margin="0,0,10,0" />

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding CountryName}" FontSize="12" FontWeight="SemiBold"
                                                                Foreground="{DynamicResource TitleTextBrush}" />
                                                    <TextBlock Text="{Binding PhotoCount, Mode=OneWay, StringFormat='{}{0} photos · {1} visits'}"
                                                               FontSize="10" Foreground="{DynamicResource GalleryStatusText}"
                                                               FontWeight="SemiBold" />
                                                </StackPanel>

                                                <TextBlock Grid.Column="2" Text="▶" FontSize="10"
                                                           Foreground="{DynamicResource GalleryStatusText}"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <!-- Top Cities -->
                    <Border Grid.Column="1"
                            Background="{DynamicResource CardBackground}"
                            CornerRadius="12" Padding="20" Margin="10,0,0,0"
                            BorderBrush="{DynamicResource GalleryTileBorder}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="🏙️ Top Cities" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TitleTextBrush}" Margin="0,0,0,10" />

                            <ItemsControl Grid.Row="1" ItemsSource="{Binding TopCities}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:TravelCity}">
                                        <Border Margin="0,0,0,6" Padding="10"
                                                Background="{DynamicResource GalleryPlaceholderBackground}"
                                                CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Text="🏙️" FontSize="16"
                                                           VerticalAlignment="Center" Margin="0,0,10,0" />

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding CityName}" FontSize="12" FontWeight="SemiBold"
                                                                Foreground="{DynamicResource TitleTextBrush}" />
                                                    <TextBlock Text="{Binding PhotoCount, Mode=OneWay, StringFormat='{}{0} photos · {1} visits'}"
                                                               FontSize="10" Foreground="{DynamicResource GalleryStatusText}"
                                                               FontWeight="SemiBold" />
                                                </StackPanel>

                                                <TextBlock Grid.Column="2" Text="▶" FontSize="10"
                                                           Foreground="{DynamicResource GalleryStatusText}"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 5. Travel Analytics -->
                <Border Grid.Row="4"
                        Background="{DynamicResource CardBackground}"
                        CornerRadius="12" Padding="20" Margin="0,0,0,20"
                        BorderBrush="{DynamicResource GalleryTileBorder}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="📊 Travel Analytics" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TitleTextBrush}" Margin="0,0,0,12" />

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding AnalyticsCards}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:TravelAnalyticsCard}">
                                    <Border Margin="4"
                                            Width="180"
                                            Padding="12"
                                            Background="{DynamicResource GalleryPlaceholderBackground}"
                                            CornerRadius="8">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding Title}" FontSize="11"
                                                           Foreground="{DynamicResource GalleryStatusText}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Value}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TitleTextBrush}"
                                                       Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding Subtitle}" FontSize="10"
                                                       Foreground="{DynamicResource GalleryStatusText}"
                                                       Visibility="{Binding Subtitle, Converter={StaticResource NullToVisibilityConverter}}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- 6. Achievements -->
                <Border Grid.Row="5"
                        Background="{DynamicResource CardBackground}"
                        CornerRadius="12" Padding="20" Margin="0,0,0,20"
                        BorderBrush="{DynamicResource GalleryTileBorder}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="🏆 Travel Achievements" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TitleTextBrush}" Margin="0,0,0,12" />

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding Achievements}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:TravelAchievement}">
                                    <Border Margin="4"
                                            Width="160"
                                            Padding="12"
                                            CornerRadius="10"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUnlocked}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource GalleryPlaceholderBackground}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryButtonBackground}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsUnlocked}" Value="False">
                                                        <Setter Property="Background" Value="{DynamicResource GalleryPlaceholderBackground}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource GalleryTileBorder}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Icon}" FontSize="24" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TitleTextBrush}"
                                                       HorizontalAlignment="Center" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding Description}" FontSize="9"
                                                       Foreground="{DynamicResource GalleryStatusText}"
                                                       HorizontalAlignment="Center"
                                                       TextWrapping="Wrap" TextAlignment="Center" />

                                            <!-- Progress Bar -->
                                            <Border Height="4" CornerRadius="2" Margin="0,6,0,0"
                                                    Background="{DynamicResource GalleryTileBorder}">
                                                <Border Height="4" CornerRadius="2"
                                                        HorizontalAlignment="Left"
                                                        Width="{Binding ProgressPercent, Mode=OneWay}"
                                                        Background="{DynamicResource PrimaryButtonBackground}" />
                                            </Border>

                                            <TextBlock Text="{Binding ProgressDisplay}" FontSize="9"
                                                       Foreground="{DynamicResource GalleryStatusText}"
                                                       HorizontalAlignment="Center" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- 7. Memory Highlights -->
                <Border Grid.Row="6"
                        Background="{DynamicResource CardBackground}"
                        CornerRadius="12" Padding="20" Margin="0,0,0,20"
                        BorderBrush="{DynamicResource GalleryTileBorder}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="✨ Memory Highlights" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TitleTextBrush}" Margin="0,0,0,12" />

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding MemoryHighlights}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:MemoryHighlight}">
                                    <Border Margin="4"
                                            Width="150"
                                            Padding="0"
                                            Background="{DynamicResource GalleryPlaceholderBackground}"
                                            CornerRadius="10"
                                            BorderBrush="{DynamicResource GalleryTileBorder}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <Border Height="80" CornerRadius="10,10,0,0" ClipToBounds="True">
                                                <Image Source="{Binding PhotoPath, Converter={StaticResource ThumbnailToBitmapConverter}}"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       Stretch="UniformToFill"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                            </Border>
                                            <Border Padding="10,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TitleTextBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Description}" FontSize="10"
                                                           Foreground="{DynamicResource GalleryStatusText}"
                                                           TextTrimming="CharacterEllipsis"
                                                            Visibility="{Binding Description, Converter={StaticResource NullToVisibilityConverter}}" />
                                            </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- 8. Map Architecture Placeholder -->
                <Border Grid.Row="7"
                        Background="{DynamicResource CardBackground}"
                        CornerRadius="12" Padding="20" Margin="0,0,0,20"
                        BorderBrush="{DynamicResource GalleryTileBorder}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="🗺️ Travel Map" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TitleTextBrush}" Margin="0,0,0,12" />

                        <Border Grid.Row="1" Height="180"
                                Background="{DynamicResource GalleryPlaceholderBackground}"
                                CornerRadius="8"
                                BorderBrush="{DynamicResource GalleryTileBorder}" BorderThickness="1">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="🗺️" FontSize="36" HorizontalAlignment="Center" />
                                <TextBlock Text="Interactive map coming soon"
                                           FontSize="13" Foreground="{DynamicResource GalleryStatusText}"
                                           HorizontalAlignment="Center" Margin="0,8,0,0" />
                                <TextBlock Text="Heatmap · Routes · Animated Journeys"
                                           FontSize="11" Foreground="{DynamicResource GalleryStatusText}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource GalleryStatusBarBackground}"
                BorderBrush="{DynamicResource GalleryStatusBarBorder}"
                BorderThickness="0,1,0,0"
                Padding="20,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding Statistics.TripsCompleted, Mode=OneWay, StringFormat='Trips: {0}'}"
                           FontSize="12" Foreground="{DynamicResource GalleryStatusText}"
                           FontWeight="SemiBold" VerticalAlignment="Center" />

                <TextBlock Grid.Column="1" Text="{Binding Statistics.CountriesVisited, Mode=OneWay, StringFormat='Countries: {0}'}"
                           FontSize="12" Foreground="{DynamicResource GalleryStatusText}"
                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="24,0,0,0" />

                <TextBlock Grid.Column="2" Text="{Binding Statistics.TotalPhotosWhileTravelling, Mode=OneWay, StringFormat='Photos: {0}'}"
                           FontSize="12" Foreground="{DynamicResource GalleryStatusText}"
                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="24,0,0,0" />

                <TextBlock Grid.Column="3" Text="{Binding Statistics.TotalDistanceKm, Mode=OneWay, StringFormat='Distance: {0:N0} km'}"
                           FontSize="12" Foreground="{DynamicResource GalleryStatusText}"
                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="24,0,0,0" />

                <TextBlock Grid.Column="4" Text="{Binding StatusMessage}" FontSize="12"
                           Foreground="{DynamicResource GalleryStatusText}"
                           TextTrimming="CharacterEllipsis" MaxWidth="300"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
