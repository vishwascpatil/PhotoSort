<UserControl x:Class="PhotoSort.Views.DuplicateDetectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:PhotoSort.Models"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{DynamicResource WindowBackground}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource GalleryStatusBarBorder}"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="&#x1F50D;"
                               FontSize="20"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <TextBlock Text="Duplicate Detection"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TitleTextBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Button Command="{Binding StartScanCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Padding="16,8"
                            FontSize="13"
                            Visibility="{Binding IsRunning, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x25B6;" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Start Scan" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding PauseScanCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="16,8"
                            FontSize="13"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}"
                            IsEnabled="{Binding IsPaused, Converter={StaticResource InverseBoolConverter}}"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x23F8;" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Pause" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ResumeScanCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="16,8"
                            FontSize="13"
                            Visibility="{Binding IsPaused, Converter={StaticResource BoolToVisibilityConverter}}"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x25B6;" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Resume" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding CancelScanCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="16,8"
                            FontSize="13"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2715;" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Cancel" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ═══ Left: Groups List ═══ -->
            <Grid Grid.Column="0">
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="{Binding HasResults, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <TextBlock Text="&#x1F50D;"
                               FontSize="48"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16" />
                    <TextBlock Text="No duplicates found yet"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TitleTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8" />
                    <TextBlock Text="Click 'Start Scan' to detect exact duplicate files"
                               FontSize="14"
                               Foreground="{DynamicResource CardDescriptionBrush}"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               MaxWidth="240" />
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding DuplicateGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:DuplicateGroup}">
                                <Border Margin="8,4"
                                        Background="{DynamicResource CardBackground}"
                                        CornerRadius="8"
                                        Padding="12"
                                        BorderBrush="{DynamicResource GalleryTileBorder}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Small thumbnail of the original -->
                                        <Border Grid.Column="0"
                                                Width="48" Height="48"
                                                CornerRadius="6"
                                                Margin="0,0,12,0"
                                                Background="{DynamicResource GalleryPlaceholderBackground}"
                                                ClipToBounds="True">
                                            <Image Source="{Binding OriginalPhoto.ThumbnailSmallPath, Converter={StaticResource ThumbnailToBitmapConverter}}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                        </Border>

                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding DuplicateCount}"
                                                           FontSize="16"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource TitleTextBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,6,0" />
                                                <TextBlock Text="duplicates"
                                                           FontSize="13"
                                                           Foreground="{DynamicResource CardDescriptionBrush}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                            <TextBlock FontSize="11"
                                                       Foreground="{DynamicResource GalleryStatusText}"
                                                       Margin="0,2,0,0">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="Size: {0}  |  Save: {1}">
                                                        <Binding Path="FileSize" Mode="OneWay" />
                                                        <Binding Path="DisplaySavings" Mode="OneWay" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Progress Overlay -->
                <Border Background="#80000000"
                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <Border Background="{DynamicResource CardBackground}"
                                CornerRadius="12"
                                Padding="32"
                                MinWidth="300">
                            <StackPanel>
                                <TextBlock Text="{Binding CurrentProgress.PhaseDisplay}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TitleTextBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,16" />

                                <Border Background="{DynamicResource GallerySkeletonBrush}"
                                        CornerRadius="4"
                                        Height="8"
                                        Margin="0,0,0,12">
                                    <Border Background="{DynamicResource PrimaryButtonBackground}"
                                            CornerRadius="4"
                                            HorizontalAlignment="Left"
                                            Width="{Binding CurrentProgress.ProgressPercent, Mode=OneWay}" />
                                </Border>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Files Processed"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource GalleryStatusText}" />
                                        <TextBlock Text="{Binding CurrentProgress.FilesProcessed, Mode=OneWay}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TitleTextBrush}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Hashes Computed"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource GalleryStatusText}" />
                                        <TextBlock Text="{Binding CurrentProgress.HashesComputed, Mode=OneWay}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TitleTextBrush}" />
                                    </StackPanel>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Candidates"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource GalleryStatusText}" />
                                        <TextBlock Text="{Binding CurrentProgress.CandidatesIdentified, Mode=OneWay}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TitleTextBrush}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Duplicates Found"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource GalleryStatusText}" />
                                        <TextBlock Text="{Binding CurrentProgress.DuplicatesFound, Mode=OneWay}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource GalleryMetricText}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ Right: Visual Comparison ═══ -->
            <Border Grid.Column="1"
                    Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource GalleryStatusBarBorder}"
                    BorderThickness="1,0,0,0"
                    Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0"
                            Padding="16,12"
                            BorderBrush="{DynamicResource GalleryStatusBarBorder}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="Duplicates for Selection"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TitleTextBrush}" />
                            <TextBlock Text="{Binding StatusMessage}"
                                       FontSize="11"
                                       Foreground="{DynamicResource GalleryStatusText}"
                                       Margin="0,4,0,0"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>

                    <!-- Comparison Area -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  Visibility="{Binding SelectedGroup, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel Margin="16,12">
                            <!-- ═══ Original Photo ═══ -->
                            <TextBlock Text="ORIGINAL"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryButtonBackground}"
                                       Margin="0,0,0,8" />

                            <Border CornerRadius="10"
                                    Padding="0"
                                    Margin="0,0,0,20"
                                    BorderBrush="{DynamicResource GalleryTileBorder}"
                                    BorderThickness="1"
                                    ClipToBounds="True"
                                    Width="320"
                                    HorizontalAlignment="Left"
                                    Background="{DynamicResource GalleryPlaceholderBackground}">
                                <Grid>
                                    <Image Source="{Binding SelectedGroup.OriginalPhoto.ThumbnailSmallPath, Converter={StaticResource ThumbnailToBitmapConverter}}"
                                           Stretch="UniformToFill"
                                           Height="240"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                    <Border VerticalAlignment="Bottom"
                                            Background="#AA000000"
                                            Padding="10,6">
                                        <TextBlock Text="{Binding SelectedGroup.OriginalPhoto.FileName}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- ═══ Duplicate Images (side-by-side) ═══ -->
                            <TextBlock Text="DUPLICATES"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource GalleryFavoriteBrush}"
                                       Margin="0,0,0,8" />

                            <ItemsControl ItemsSource="{Binding SelectedGroup.Duplicates}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:DuplicatePhoto}">
                                        <Border CornerRadius="10"
                                                Margin="0,0,12,12"
                                                BorderBrush="{DynamicResource GalleryTileBorder}"
                                                BorderThickness="1"
                                                ClipToBounds="True"
                                                Width="240"
                                                Background="{DynamicResource GalleryPlaceholderBackground}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <!-- Thumbnail -->
                                                <Border Grid.Row="0"
                                                        Height="180"
                                                        ClipToBounds="True">
                                                    <Image Source="{Binding ThumbnailSmallPath, Converter={StaticResource ThumbnailToBitmapConverter}}"
                                                           Stretch="UniformToFill"
                                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                                </Border>

                                                <!-- Info & Actions -->
                                                <Border Grid.Row="1"
                                                        Padding="10,8"
                                                        Background="{DynamicResource CardBackground}">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding FileName}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TitleTextBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="0,0,0,4" />

                                                    <StackPanel Orientation="Horizontal"
                                                                Margin="0,0,0,6">
                                                        <TextBlock Text="{Binding DisplaySize}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource GalleryStatusText}"
                                                                   Margin="0,0,12,0" />
                                                        <TextBlock Text="{Binding DisplayDate}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource GalleryStatusText}" />
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Command="{Binding DataContext.MarkAsOriginalCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource SecondaryButton}"
                                                                Padding="8,4"
                                                                FontSize="11"
                                                                Margin="0,0,6,0">
                                                            <TextBlock Text="Keep This" />
                                                        </Button>
                                                        <Button Command="{Binding DataContext.DeleteDuplicateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource SecondaryButton}"
                                                                Padding="8,4"
                                                                FontSize="11">
                                                            <TextBlock Text="Delete"
                                                                       Foreground="{DynamicResource GalleryFavoriteBrush}" />
                                                        </Button>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource GalleryStatusBarBackground}"
                BorderBrush="{DynamicResource GalleryStatusBarBorder}"
                BorderThickness="0,1,0,0"
                Padding="20,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           FontSize="12"
                           Foreground="{DynamicResource GalleryStatusText}"
                           VerticalAlignment="Center"
                           Text="{Binding DuplicateGroups.Count, Mode=OneWay, StringFormat='Groups: {0}'}" />

                <TextBlock Grid.Column="1"
                           FontSize="12"
                           Foreground="{DynamicResource GalleryStatusText}"
                           VerticalAlignment="Center"
                           Margin="24,0,0,0"
                           Text="{Binding CurrentProgress.DuplicatesFound, Mode=OneWay, StringFormat='Duplicates: {0}'}" />

                <TextBlock Grid.Column="2"
                           FontSize="12"
                           Foreground="{DynamicResource GalleryStatusText}"
                           VerticalAlignment="Center"
                           Margin="24,0,0,0"
                           Text="{Binding CurrentProgress.DisplayReclaimable, Mode=OneWay, StringFormat='Savings: {0}'}" />

                <TextBlock Grid.Column="4"
                           Text="{Binding StatusMessage}"
                           FontSize="12"
                           Foreground="{DynamicResource GalleryStatusText}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="300"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
