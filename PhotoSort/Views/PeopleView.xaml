<UserControl x:Class="PhotoSort.Views.PeopleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:PhotoSort.Models"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{DynamicResource WindowBackground}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource GalleryStatusBarBorder}"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="&#x1F464;"
                               FontSize="20"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <TextBlock Text="People"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TitleTextBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <!-- Start Processing -->
                    <Button Command="{Binding StartProcessingCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Padding="16,8"
                            FontSize="13"
                            Visibility="{Binding IsProcessing, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x25B6;" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Start Detection" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Pause -->
                    <Button Command="{Binding PauseProcessingCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="16,8"
                            FontSize="13"
                            Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}"
                            IsEnabled="{Binding IsPaused, Converter={StaticResource InverseBoolConverter}}"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x23F8;" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Pause" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Resume -->
                    <Button Command="{Binding ResumeProcessingCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="16,8"
                            FontSize="13"
                            Visibility="{Binding IsPaused, Converter={StaticResource BoolToVisibilityConverter}}"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x25B6;" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Resume" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Cancel -->
                    <Button Command="{Binding CancelProcessingCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="16,8"
                            FontSize="13"
                            Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2715;" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Cancel" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <!-- Left: People Grid -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Stats -->
                <Border Grid.Row="0"
                        Margin="16,16,16,0"
                        Background="{DynamicResource CardBackground}"
                        CornerRadius="12"
                        Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="&#x1F465;" FontSize="20" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding TotalPeopleCount}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource GalleryMetricText}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="People" FontSize="11"
                                       Foreground="{DynamicResource GalleryStatusText}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="&#x1F5BC;" FontSize="20" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding TotalFaceCount}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource GalleryMetricText}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Faces" FontSize="11"
                                       Foreground="{DynamicResource GalleryStatusText}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="&#x1F4F1;" FontSize="20" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding UnprocessedPhotoCount}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource GalleryMetricText}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Pending" FontSize="11"
                                       Foreground="{DynamicResource GalleryStatusText}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                            <TextBlock Text="&#x1F3A8;" FontSize="20" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding EmbeddedFaceCount}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource GalleryMetricText}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Embedded" FontSize="11"
                                       Foreground="{DynamicResource GalleryStatusText}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- People Grid -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Margin="16,16,16,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Empty State -->
                        <StackPanel Grid.Row="0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Visibility="{Binding HasPeople, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <TextBlock Text="&#x1F464;"
                                       FontSize="48"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,16" />
                            <TextBlock Text="No people detected yet"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TitleTextBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="Click 'Start Detection' to find faces in your photos"
                                       FontSize="14"
                                       Foreground="{DynamicResource CardDescriptionBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <!-- People Tiles -->
                        <ItemsControl Grid.Row="1"
                                      ItemsSource="{Binding People}"
                                      Visibility="{Binding HasPeople, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:PersonInfo}">
                                    <Border Margin="8"
                                            Width="140"
                                            Background="{DynamicResource CardBackground}"
                                            CornerRadius="12"
                                            Padding="12"
                                            BorderBrush="{DynamicResource GalleryTileBorder}"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="OnPersonClick">
                                        <StackPanel HorizontalAlignment="Center">
                                            <!-- Thumbnail -->
                                            <Border Width="80"
                                                    Height="80"
                                                    CornerRadius="40"
                                                    ClipToBounds="True"
                                                    Background="{DynamicResource GalleryPlaceholderBackground}"
                                                    HorizontalAlignment="Center"
                                                    Margin="0,0,0,10">
                                                <Image Source="{Binding ThumbnailPath, Converter={StaticResource ThumbnailToBitmapConverter}}"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       Stretch="UniformToFill"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                            </Border>

                                            <!-- Name -->
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TitleTextBrush}"
                                                       HorizontalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="120" />

                                            <!-- Face Count -->
                                            <TextBlock Text="{Binding DisplayFaceCount}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource GalleryStatusText}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,2,0,0" />

                                            <!-- Last Seen -->
                                            <TextBlock Text="{Binding DisplayLastSeen}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource GalleryStatusText}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </ScrollViewer>

                <!-- Progress Overlay -->
                <Border Background="#80000000"
                        Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <Border Background="{DynamicResource CardBackground}"
                                CornerRadius="12"
                                Padding="32"
                                MinWidth="320">
                            <StackPanel>
                                <TextBlock Text="{Binding CurrentPhaseDisplay}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TitleTextBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,16" />

                                <TextBlock FontSize="12"
                                           Foreground="{DynamicResource GalleryStatusText}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Processing {0} of {1} photos ({2:F0}%)">
                                            <Binding Path="CurrentPhotosProcessed" Mode="OneWay" />
                                            <Binding Path="CurrentTotalPhotos" Mode="OneWay" />
                                            <Binding Path="CurrentProgressPercent" Mode="OneWay" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>

                                <Border Background="{DynamicResource GallerySkeletonBrush}"
                                        CornerRadius="4"
                                        Height="8"
                                        Margin="0,0,0,12">
                                    <Border Background="{DynamicResource PrimaryButtonBackground}"
                                            CornerRadius="4"
                                            HorizontalAlignment="Left"
                                            Width="{Binding CurrentProgressPercent, Mode=OneWay}" />
                                </Border>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Photos Processed"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource GalleryStatusText}" />
                                        <TextBlock Text="{Binding CurrentPhotosProcessed, Mode=OneWay}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TitleTextBrush}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Faces Detected"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource GalleryStatusText}" />
                                        <TextBlock Text="{Binding CurrentFacesDetected, Mode=OneWay}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TitleTextBrush}" />
                                    </StackPanel>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Embeddings"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource GalleryStatusText}" />
                                        <TextBlock Text="{Binding CurrentEmbeddingsGenerated, Mode=OneWay}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TitleTextBrush}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="People Found"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource GalleryStatusText}" />
                                        <TextBlock Text="{Binding CurrentPeopleIdentified, Mode=OneWay}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource GalleryMetricText}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Right: Person Details -->
            <Border Grid.Column="1"
                    Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource GalleryStatusBarBorder}"
                    BorderThickness="1,0,0,0"
                    Visibility="{Binding HasSelectedPerson, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Person Header -->
                    <Border Grid.Row="0"
                            Padding="16,12"
                            BorderBrush="{DynamicResource GalleryStatusBarBorder}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Name Display -->
                                <StackPanel Grid.Column="0"
                                            Visibility="{Binding IsRenameMode, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                    <TextBlock Text="{Binding SelectedPerson.Name}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TitleTextBrush}" />
                                    <TextBlock FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource GalleryStatusText}"
                                               Margin="0,4,0,0">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} faces  |  {1} photos">
                                                <Binding Path="SelectedPerson.FaceCount" Mode="OneWay" />
                                                <Binding Path="SelectedPerson.PhotoCount" Mode="OneWay" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Rename Input -->
                                <StackPanel Grid.Column="0"
                                            Orientation="Horizontal"
                                            Visibility="{Binding IsRenameMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBox Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}"
                                             Width="200"
                                             Height="28"
                                             FontSize="13"
                                             Margin="0,0,8,0"
                                             VerticalContentAlignment="Center" />
                                    <Button Command="{Binding RenamePersonCommand}"
                                            Style="{StaticResource PrimaryButton}"
                                            Padding="8,4"
                                            FontSize="11">
                                        <TextBlock Text="Save" />
                                    </Button>
                                </StackPanel>

                                <!-- Rename Button -->
                                <Button Grid.Column="1"
                                        Command="{Binding RenamePersonCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="8,4"
                                        FontSize="11"
                                        Visibility="{Binding IsRenameMode, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                        ToolTip="Rename this person">
                                    <TextBlock Text="Rename" />
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Row="1"
                                Margin="16,12">
                        <!-- Row 1: Merge, Reprocess -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Command="{Binding MergePeopleCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Padding="10,6"
                                    FontSize="11"
                                    Margin="0,0,6,0"
                                    IsEnabled="{Binding SelectedPersonIds.Count, Converter={StaticResource NonZeroToBoolConverter}}">
                                <TextBlock Text="Merge Selected" />
                            </Button>
                            <Button Command="{Binding ReprocessPersonCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="10,6"
                                    FontSize="11"
                                    Margin="0,0,6,0">
                                <TextBlock Text="Reprocess" />
                            </Button>
                            <Button Command="{Binding DeletePersonCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="10,6"
                                    FontSize="11">
                                <TextBlock Text="Delete" Foreground="{DynamicResource GalleryFavoriteBrush}" />
                            </Button>
                        </StackPanel>

                        <!-- Row 2: Split Mode Toggle -->
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding ToggleSplitModeCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="10,6"
                                    FontSize="11"
                                    Margin="0,0,6,0">
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Enter Split Mode" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSplitMode}" Value="True">
                                                    <Setter Property="Text" Value="Cancel Split" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>

                            <!-- Split Confirm (visible in split mode) -->
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding IsSplitMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBox Text="{Binding NewPersonName, UpdateSourceTrigger=PropertyChanged}"
                                         Width="140"
                                         Height="28"
                                         FontSize="11"
                                         Margin="0,0,6,0"
                                         VerticalContentAlignment="Center"
                                         ToolTip="New person name (optional)" />
                                <Button Command="{Binding SplitPersonCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Padding="10,6"
                                        FontSize="11"
                                        IsEnabled="{Binding SplitFaceIds.Count, Converter={StaticResource NonZeroToBoolConverter}}">
                                    <TextBlock Text="{Binding SplitFaceIds.Count, StringFormat='Split ({0})'}" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Faces Grid -->
                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  Margin="16,0">
                        <ItemsControl ItemsSource="{Binding SelectedPersonFaces}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:FaceInfo}">
                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            Background="{DynamicResource CardBackground}"
                                            CornerRadius="8"
                                            BorderBrush="{DynamicResource GalleryTileBorder}"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="OnFaceClick">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Split Checkbox (visible in split mode) -->
                                            <Border Grid.Column="0"
                                                    Width="20"
                                                    Height="20"
                                                    CornerRadius="4"
                                                    BorderBrush="{DynamicResource GalleryTileBorder}"
                                                    BorderThickness="1"
                                                    Background="{DynamicResource GalleryPlaceholderBackground}"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,8,0"
                                                    Visibility="{Binding DataContext.IsSplitMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="&#x2713;"
                                                           FontSize="12"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource PrimaryButtonBackground}" />
                                            </Border>

                                            <!-- Face Thumbnail -->
                                            <Border Grid.Column="0"
                                                    Width="45"
                                                    Height="45"
                                                    CornerRadius="4"
                                                    ClipToBounds="True"
                                                    Background="{DynamicResource GalleryPlaceholderBackground}"
                                                    Margin="0,0,10,0">
                                                <Image Source="{Binding ThumbnailPath, Converter={StaticResource ThumbnailToBitmapConverter}}"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       Stretch="UniformToFill"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                            </Border>

                                            <!-- Face Info -->
                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FileName}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TitleTextBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding DisplayConfidence, Mode=OneWay, StringFormat='{}{0} confidence'}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource GalleryStatusText}"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>

                                            <!-- Action Buttons -->
                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                 <Button Command="{Binding DataContext.IgnoreFaceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                         CommandParameter="{Binding}"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Padding="6,4"
                                                        FontSize="10"
                                                        Margin="0,0,4,0">
                                                    <TextBlock Text="Ignore"
                                                               Foreground="{DynamicResource GalleryFavoriteBrush}" />
                                                </Button>
                                                 <Button Command="{Binding DataContext.DeleteFaceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                         CommandParameter="{Binding}"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Padding="6,4"
                                                        FontSize="10">
                                                    <TextBlock Text="Delete"
                                                               Foreground="{DynamicResource GalleryFavoriteBrush}" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- No Selection State -->
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{Binding HasSelectedPerson, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <TextBlock Text="Select a person"
                           FontSize="14"
                           Foreground="{DynamicResource GalleryStatusText}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource GalleryStatusBarBackground}"
                BorderBrush="{DynamicResource GalleryStatusBarBorder}"
                BorderThickness="0,1,0,0"
                Padding="20,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding TotalPeopleCount, Mode=OneWay, StringFormat='People: {0}'}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource GalleryMetricText}"
                           VerticalAlignment="Center" />

                <TextBlock Grid.Column="1"
                           Text="{Binding TotalFaceCount, Mode=OneWay, StringFormat='Faces: {0}'}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource GalleryMetricText}"
                           VerticalAlignment="Center"
                           Margin="24,0,0,0" />

                <TextBlock Grid.Column="2"
                           Text="{Binding EmbeddedFaceCount, Mode=OneWay, StringFormat='Embedded: {0}'}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource GalleryMetricText}"
                           VerticalAlignment="Center"
                           Margin="24,0,0,0" />

                <TextBlock Grid.Column="3"
                           Text="{Binding UnprocessedPhotoCount, Mode=OneWay, StringFormat='Pending: {0}'}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource GalleryMetricText}"
                           VerticalAlignment="Center"
                           Margin="24,0,0,0" />

                <!-- Split Mode Indicator -->
                <Border Grid.Column="4"
                        VerticalAlignment="Center"
                        Margin="24,0,0,0"
                        Visibility="{Binding IsSplitMode, Converter={StaticResource BoolToVisibilityConverter}}"
                        Background="{DynamicResource PrimaryButtonBackground}"
                        CornerRadius="4"
                        Padding="8,2">
                    <TextBlock FontSize="11"
                               Foreground="White"
                               FontWeight="SemiBold"
                               Text="SPLIT MODE - Select faces to split" />
                </Border>

                <TextBlock Grid.Column="5"
                           Text="{Binding StatusMessage}"
                           FontSize="12"
                           Foreground="{DynamicResource GalleryStatusText}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="300"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
