<UserControl x:Class="PhotoSort.Views.PeopleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:PhotoSort.Models"
             xmlns:vm="clr-namespace:PhotoSort.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{DynamicResource WindowBackground}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header with Title + Search -->
        <Border Grid.Row="0"
                Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource GalleryStatusBarBorder}"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="People"
                               FontSize="24" FontWeight="SemiBold"
                               Foreground="{DynamicResource TitleTextBrush}" />
                    <TextBlock Text="Recognized faces from your local photo library."
                               FontSize="14"
                               Foreground="{DynamicResource GalleryStatusText}"
                               Margin="0,2,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Top">
                    <Button Command="{Binding StartProcessingCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Padding="16,8"
                            FontSize="13"
                            Visibility="{Binding IsProcessing, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x25B6;" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Scan Folders" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding PauseProcessingCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="16,8"
                            FontSize="13"
                            Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}"
                            IsEnabled="{Binding IsPaused, Converter={StaticResource InverseBoolConverter}}"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x23F8;" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Pause" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ResumeProcessingCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="16,8"
                            FontSize="13"
                            Visibility="{Binding IsPaused, Converter={StaticResource BoolToVisibilityConverter}}"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x25B6;" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Resume" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding CancelProcessingCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="16,8"
                            FontSize="13"
                            Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2715;" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Cancel" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Search Bar -->
                <Border Grid.Row="1" Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Margin="0,12,0,0"
                        Background="{DynamicResource SurfaceContainerLow}"
                        CornerRadius="20"
                        BorderBrush="{DynamicResource GalleryStatusBarBorder}"
                        BorderThickness="1"
                        Padding="12,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="&#x1F50D;"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="4,0,8,0" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"
                                 Foreground="{DynamicResource TitleTextBrush}"
                                 FontFamily="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Escape" Command="{Binding ClearSearchCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="380"
                                  MinWidth="320" />
            </Grid.ColumnDefinitions>

            <!-- Left: People Content -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          Padding="24,16,16,16">
                <StackPanel>

                    <!-- ===== Unnamed Faces Section ===== -->
                    <Border x:Name="UnnamedSection"
                            Background="{DynamicResource SurfaceContainerLow}"
                            CornerRadius="16"
                            Padding="24"
                            BorderBrush="{DynamicResource GalleryStatusBarBorder}"
                            BorderThickness="1"
                            Margin="0,0,0,24"
                            Visibility="{Binding HasUnnamedFaces, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <!-- Section Header -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="&#x1F9E0;"
                                           FontSize="20"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBlock Grid.Column="1"
                                           Text="Identify These Faces"
                                           FontSize="18" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TitleTextBrush}"
                                           VerticalAlignment="Center" />
                                <Border Grid.Column="2"
                                        Background="{DynamicResource ErrorContainer}"
                                        CornerRadius="10"
                                        Padding="8,2"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left">
                                    <TextBlock FontSize="11" FontWeight="Bold"
                                               Foreground="{DynamicResource OnErrorContainer}">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} Needs naming">
                                                <Binding Path="UnnamedFaces.Count" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Border>

                                <Button Grid.Column="3"
                                        Command="{Binding DismissAllUnnamedCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="8,4"
                                        FontSize="11"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="Dismiss all" />
                                </Button>
                            </Grid>

                            <!-- Unnamed Face Grid -->
                            <ItemsControl ItemsSource="{Binding UnnamedFaces}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:FaceInfo}">
                                        <Border Margin="6"
                                                Padding="4"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="OnUnnamedFaceClick">
                                            <StackPanel HorizontalAlignment="Center">
                                                <Border Width="100"
                                                        Height="100"
                                                        CornerRadius="50"
                                                        ClipToBounds="True"
                                                        BorderBrush="{DynamicResource PrimaryButtonBackground}"
                                                        BorderThickness="2"
                                                        
                                                        Background="{DynamicResource GalleryPlaceholderBackground}">
                                                    <Grid>
                                                        <Image Source="{Binding ThumbnailPath, Converter={StaticResource ThumbnailToBitmapConverter}}"
                                                               RenderOptions.BitmapScalingMode="HighQuality"
                                                               Stretch="UniformToFill"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                        <Border VerticalAlignment="Bottom"
                                                                HorizontalAlignment="Right"
                                                                Background="{DynamicResource PrimaryButtonBackground}"
                                                                CornerRadius="12"
                                                                Width="24" Height="24"
                                                                Margin="0,0,2,2"
                                                                BorderThickness="2"
                                                                BorderBrush="{DynamicResource CardBackground}">
                                                            <TextBlock Text="&#x270F;"
                                                                       FontSize="12"
                                                                       Foreground="White"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" />
                                                        </Border>
                                                    </Grid>
                                                </Border>

                                                <TextBlock Text="Add Name"
                                                           FontSize="12" FontWeight="Bold"
                                                           Foreground="{DynamicResource PrimaryButtonBackground}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,6,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- ===== Empty State ===== -->
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Visibility="{Binding HasPeople, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                Margin="0,60,0,0">
                        <TextBlock Text="&#x1F464;"
                                   FontSize="48"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,16" />
                        <TextBlock Text="No people detected yet"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TitleTextBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="Click 'Scan Folders' to find faces in your photos"
                                   FontSize="14"
                                   Foreground="{DynamicResource CardDescriptionBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- ===== Your Collection Section ===== -->
                    <StackPanel Visibility="{Binding HasPeople, Converter={StaticResource BoolToVisibilityConverter}}">
                        <!-- Section Header -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Your Collection"
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TitleTextBrush}"
                                       VerticalAlignment="Center" />

                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Sort by:"
                                           FontSize="12"
                                           Foreground="{DynamicResource GalleryStatusText}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0" />
                                <ComboBox SelectedIndex="{Binding SortMode, Mode=TwoWay}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          FontSize="12"
                                          Foreground="{DynamicResource PrimaryButtonBackground}"
                                          Cursor="Hand"
                                          MinWidth="100">
                                    <ComboBoxItem Content="Most Frequent" />
                                    <ComboBoxItem Content="Alphabetical" />
                                    <ComboBoxItem Content="Recent" />
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <!-- People Grid -->
                        <ItemsControl ItemsSource="{Binding FilteredPeople}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:PersonInfo}">
                                    <Border Margin="8"
                                            Padding="8"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="OnPersonClick"
                                            Background="Transparent"
                                            CornerRadius="12">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource SurfaceContainerHigh}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel HorizontalAlignment="Center">
                                            <!-- Circular Thumbnail -->
                                            <Border Width="128"
                                                    Height="128"
                                                    CornerRadius="64"
                                                    ClipToBounds="True"
                                                    Background="{DynamicResource GalleryPlaceholderBackground}"
                                                    HorizontalAlignment="Center"
                                                    Margin="0,0,0,8"
                                                    BorderBrush="{DynamicResource GalleryStatusBarBorder}"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Image Source="{Binding ThumbnailPath, Converter={StaticResource ThumbnailToBitmapConverter}}"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           Stretch="UniformToFill"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Opacity" Value="0.5" />
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Opacity" Value="1" />
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                    <Border Opacity="0"
                                                            Background="{DynamicResource PrimaryButtonBackground}"
                                                            CornerRadius="64"
                                                            MouseLeftButtonDown="OnPersonClick">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Opacity" Value="0.1" />
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <!-- Name -->
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TitleTextBrush}"
                                                       HorizontalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="140" />

                                            <!-- Photo Count -->
                                            <TextBlock Text="{Binding DisplayPhotoCount}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource GalleryStatusText}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Right: Person Details -->
            <Border Grid.Column="1"
                    Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource GalleryStatusBarBorder}"
                    BorderThickness="1,0,0,0"
                    Visibility="{Binding HasSelectedPerson, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Person Header -->
                    <Border Grid.Row="0"
                            Padding="16,12"
                            BorderBrush="{DynamicResource GalleryStatusBarBorder}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Visibility="{Binding IsRenameMode, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                    <TextBlock Text="{Binding SelectedPerson.Name}"
                                               FontSize="16" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TitleTextBrush}" />
                                    <TextBlock FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource GalleryStatusText}"
                                               Margin="0,4,0,0">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} faces  |  {1} photos">
                                                <Binding Path="SelectedPerson.FaceCount" Mode="OneWay" />
                                                <Binding Path="SelectedPerson.PhotoCount" Mode="OneWay" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Grid.Column="0"
                                            Orientation="Horizontal"
                                            Visibility="{Binding IsRenameMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBox Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}"
                                             Width="200" Height="28"
                                             FontSize="13"
                                             Margin="0,0,8,0"
                                             VerticalContentAlignment="Center" />
                                    <Button Command="{Binding RenamePersonCommand}"
                                            Style="{StaticResource PrimaryButton}"
                                            Padding="8,4"
                                            FontSize="11">
                                        <TextBlock Text="Save" />
                                    </Button>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Command="{Binding RenamePersonCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="8,4"
                                        FontSize="11"
                                        Visibility="{Binding IsRenameMode, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                        ToolTip="Rename this person">
                                    <TextBlock Text="Rename" />
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Row="1"
                                Margin="16,12">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Command="{Binding MergePeopleCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Padding="10,6"
                                    FontSize="11"
                                    Margin="0,0,6,0"
                                    IsEnabled="{Binding SelectedPersonIds.Count, Converter={StaticResource NonZeroToBoolConverter}}">
                                <TextBlock Text="Merge Selected" />
                            </Button>
                            <Button Command="{Binding ReprocessPersonCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="10,6"
                                    FontSize="11"
                                    Margin="0,0,6,0">
                                <TextBlock Text="Reprocess" />
                            </Button>
                            <Button Command="{Binding DeletePersonCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="10,6"
                                    FontSize="11">
                                <TextBlock Text="Delete" Foreground="{DynamicResource GalleryFavoriteBrush}" />
                            </Button>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding ToggleSplitModeCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="10,6"
                                    FontSize="11"
                                    Margin="0,0,6,0">
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Enter Split Mode" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSplitMode}" Value="True">
                                                    <Setter Property="Text" Value="Cancel Split" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>

                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding IsSplitMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBox Text="{Binding NewPersonName, UpdateSourceTrigger=PropertyChanged}"
                                         Width="140" Height="28"
                                         FontSize="11"
                                         Margin="0,0,6,0"
                                         VerticalContentAlignment="Center"
                                         ToolTip="New person name (optional)" />
                                <Button Command="{Binding SplitPersonCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Padding="10,6"
                                        FontSize="11"
                                        IsEnabled="{Binding SplitFaceIds.Count, Converter={StaticResource NonZeroToBoolConverter}}">
                                    <TextBlock Text="{Binding SplitFaceIds.Count, StringFormat='Split ({0})'}" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Faces Grid -->
                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  Margin="16,0">
                        <ItemsControl ItemsSource="{Binding SelectedPersonFaces}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:FaceInfo}">
                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            Background="{DynamicResource CardBackground}"
                                            CornerRadius="8"
                                            BorderBrush="{DynamicResource GalleryTileBorder}"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="OnFaceClick">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Width="20" Height="20"
                                                    CornerRadius="4"
                                                    BorderBrush="{DynamicResource GalleryTileBorder}"
                                                    BorderThickness="1"
                                                    Background="{DynamicResource GalleryPlaceholderBackground}"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,8,0"
                                                    Visibility="{Binding DataContext.IsSplitMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="&#x2713;"
                                                           FontSize="12"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource PrimaryButtonBackground}" />
                                            </Border>

                                            <Border Grid.Column="0"
                                                    Width="45" Height="45"
                                                    CornerRadius="4"
                                                    ClipToBounds="True"
                                                    Background="{DynamicResource GalleryPlaceholderBackground}"
                                                    Margin="0,0,10,0">
                                                <Image Source="{Binding ThumbnailPath, Converter={StaticResource ThumbnailToBitmapConverter}}"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       Stretch="UniformToFill"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                            </Border>

                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FileName}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TitleTextBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding DisplayConfidence, Mode=OneWay, StringFormat='{}{0} confidence'}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource GalleryStatusText}"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Button Command="{Binding DataContext.IgnoreFaceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Padding="6,4"
                                                        FontSize="10"
                                                        Margin="0,0,4,0">
                                                    <TextBlock Text="Ignore"
                                                               Foreground="{DynamicResource GalleryFavoriteBrush}" />
                                                </Button>
                                                <Button Command="{Binding DataContext.DeleteFaceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Padding="6,4"
                                                        FontSize="10">
                                                    <TextBlock Text="Delete"
                                                               Foreground="{DynamicResource GalleryFavoriteBrush}" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- No Selection State -->
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{Binding HasSelectedPerson, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <TextBlock Text="Select a person"
                           FontSize="14"
                           Foreground="{DynamicResource GalleryStatusText}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource GalleryStatusBarBackground}"
                BorderBrush="{DynamicResource GalleryStatusBarBorder}"
                BorderThickness="0,1,0,0"
                Padding="20,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding TotalPeopleCount, Mode=OneWay, StringFormat='People: {0}'}"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource GalleryMetricText}"
                           VerticalAlignment="Center" />

                <TextBlock Grid.Column="1"
                           Text="{Binding TotalFaceCount, Mode=OneWay, StringFormat='Faces: {0}'}"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource GalleryMetricText}"
                           VerticalAlignment="Center"
                           Margin="24,0,0,0" />

                <TextBlock Grid.Column="2"
                           Text="{Binding EmbeddedFaceCount, Mode=OneWay, StringFormat='Embedded: {0}'}"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource GalleryMetricText}"
                           VerticalAlignment="Center"
                           Margin="24,0,0,0" />

                <TextBlock Grid.Column="3"
                           Text="{Binding UnprocessedPhotoCount, Mode=OneWay, StringFormat='Pending: {0}'}"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource GalleryMetricText}"
                           VerticalAlignment="Center"
                           Margin="24,0,0,0" />

                <Border Grid.Column="4"
                        VerticalAlignment="Center"
                        Margin="24,0,0,0"
                        Visibility="{Binding IsSplitMode, Converter={StaticResource BoolToVisibilityConverter}}"
                        Background="{DynamicResource PrimaryButtonBackground}"
                        CornerRadius="4"
                        Padding="8,2">
                    <TextBlock FontSize="11"
                               Foreground="White"
                               FontWeight="SemiBold"
                               Text="SPLIT MODE - Select faces to split" />
                </Border>

                <TextBlock Grid.Column="5"
                           Text="{Binding StatusMessage}"
                           FontSize="12"
                           Foreground="{DynamicResource GalleryStatusText}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="300"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- FAB: Add New Person -->
        <Button Grid.Row="1"
                Command="{Binding AddNewPersonCommand}"
                Width="56" Height="56"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,24,24"
                Panel.ZIndex="10"
                ToolTip="Add new person">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{DynamicResource PrimaryButtonBackground}"
                            CornerRadius="28"
                            BorderThickness="0">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryButtonHover}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
            <TextBlock Text="&#x2795;"
                       FontSize="28"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Button>

        <!-- Processing Overlay -->
        <Border Grid.Row="1"
                Background="#80000000"
                Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}"
                Panel.ZIndex="20">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="12"
                        Padding="32"
                        MinWidth="320">
                    <StackPanel>
                        <TextBlock Text="{Binding CurrentPhaseDisplay}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TitleTextBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,16" />

                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource GalleryStatusText}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="Processing {0} of {1} photos ({2:F0}%)">
                                    <Binding Path="CurrentPhotosProcessed" Mode="OneWay" />
                                    <Binding Path="CurrentTotalPhotos" Mode="OneWay" />
                                    <Binding Path="CurrentProgressPercent" Mode="OneWay" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                        <Border Background="{DynamicResource GallerySkeletonBrush}"
                                CornerRadius="4"
                                Height="8"
                                Margin="0,0,0,12">
                            <Border Background="{DynamicResource PrimaryButtonBackground}"
                                    CornerRadius="4"
                                    HorizontalAlignment="Left"
                                    Width="{Binding CurrentProgressPercent, Mode=OneWay}" />
                        </Border>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Photos Processed"
                                           FontSize="10"
                                           Foreground="{DynamicResource GalleryStatusText}" />
                                <TextBlock Text="{Binding CurrentPhotosProcessed, Mode=OneWay}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TitleTextBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Faces Detected"
                                           FontSize="10"
                                           Foreground="{DynamicResource GalleryStatusText}" />
                                <TextBlock Text="{Binding CurrentFacesDetected, Mode=OneWay}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TitleTextBrush}" />
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Embeddings"
                                           FontSize="10"
                                           Foreground="{DynamicResource GalleryStatusText}" />
                                <TextBlock Text="{Binding CurrentEmbeddingsGenerated, Mode=OneWay}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TitleTextBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="People Found"
                                           FontSize="10"
                                           Foreground="{DynamicResource GalleryStatusText}" />
                                <TextBlock Text="{Binding CurrentPeopleIdentified, Mode=OneWay}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource GalleryMetricText}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>