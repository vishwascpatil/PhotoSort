<UserControl x:Class="PhotoSort.Views.Memories.MemoriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:PhotoSort.ViewModels"
             d:DataContext="{d:DesignInstance vm:MemoriesViewModel}"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource WindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding SectionTitle}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource TitleTextBrush}" />
                    <TextBlock Text="{Binding UnreadCount, StringFormat='{}{0} memories'}"

                               FontSize="12"
                               Foreground="{DynamicResource SubtitleTextBrush}"
                               Margin="0,2,0,0" />
                </StackPanel>
                <Button Grid.Column="1"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Padding="10,6" FontSize="12"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F504;" FontSize="12" Margin="0,0,4,0" />
                        <TextBlock Text="Refresh" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Memories List -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Margin="20,0,20,20">
            <Grid>
                <ItemsControl ItemsSource="{Binding Memories}"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:MemoryItemViewModel}">
                        <Border Width="280" Height="200" Margin="8"
                                CornerRadius="12"
                                Background="{DynamicResource CardBackground}"
                                BorderBrush="{DynamicResource CardBorderBrush}"
                                BorderThickness="1"
                                Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick"
                                    Command="{Binding DataContext.OpenMemoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}" />
                            </Border.InputBindings>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Cover Image -->
                                <Border Grid.Row="0"
                                        CornerRadius="12,12,0,0"
                                        ClipToBounds="True"
                                        Background="{DynamicResource GalleryPlaceholderBackground}">
                                    <Grid>
                                        <Image Source="{Binding CoverBitmap}"
                                               Stretch="UniformToFill"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center" />
                                        <!-- Type Badge -->
                                        <Border HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Margin="8"
                                                Background="#99000000"
                                                CornerRadius="4"
                                                Padding="6,3">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding TypeIcon}" FontSize="12" />
                                                <TextBlock Text="{Binding Type}"
                                                           FontSize="10" FontWeight="SemiBold"
                                                           Foreground="White"
                                                           Margin="4,0,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Info -->
                                <StackPanel Grid.Row="1" Margin="14,10">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource CardTitleBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Subtitle}"
                                               FontSize="11"
                                               Foreground="{DynamicResource CardDescriptionBrush}"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

                <!-- Empty State -->
                <Border Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVisibilityConverter}}"
                        Background="Transparent">
                    <TextBlock Text="{Binding StatusMessage, TargetNullValue='No memories yet. Click Refresh to generate, or add photos to your library first.'}"
                               FontSize="16"
                               Foreground="{DynamicResource SubtitleTextBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="40" />
                </Border>

                <!-- Pipeline Running Indicator -->
                <Border Visibility="{Binding IsPipelineRunning, Converter={StaticResource BoolToVisibilityConverter}}"
                        Background="#CCFFFFFF"
                        CornerRadius="8"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,20,0,0"
                        Padding="20,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x23F3;" FontSize="16" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding StatusMessage, TargetNullValue='Generating memories from your photos...'}"
                                   FontSize="13"
                                   Foreground="{DynamicResource TitleTextBrush}" />
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
