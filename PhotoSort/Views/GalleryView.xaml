<UserControl x:Class="PhotoSort.Views.GalleryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:PhotoSort.Views"
             xmlns:models="clr-namespace:PhotoSort.Models"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="{DynamicResource WindowBackground}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource GalleryStatusBarBorder}"
                BorderThickness="0,0,0,1" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Sort / View Controls -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding ToggleViewModeCommand}"
                            Style="{StaticResource SecondaryButton}" Padding="14,7" FontSize="12" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4C2;" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding ViewModeText}" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ToggleSortModeCommand}"
                            Style="{StaticResource SecondaryButton}" Padding="14,7" FontSize="12"
                            Visibility="{Binding IsTimelineView, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x21C5;" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding CurrentSortMode, Converter={StaticResource SortModeLabelConverter}}"
                                       FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <TextBlock Text="{Binding TimelineSummary}" FontSize="11"
                               Foreground="{DynamicResource GalleryStatusText}" VerticalAlignment="Center" Margin="12,0,0,0"
                               Visibility="{Binding IsTimelineView, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>

                <!-- Thumbnail Status -->
                <TextBlock Grid.Column="2" Text="{Binding ThumbnailStatus, Mode=OneWay}"
                           FontSize="11" Foreground="{DynamicResource GalleryStatusText}"
                           TextTrimming="CharacterEllipsis" MaxWidth="200"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Gallery Content -->
        <Grid Grid.Row="1">
            <!-- Empty State -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding IsGalleryEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="&#x1F4F7;" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16" />
                <TextBlock Text="No photos yet" FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource TitleTextBrush}" HorizontalAlignment="Center" Margin="0,0,0,8" />
                <TextBlock Text="Import a folder to start building your gallery" FontSize="14"
                           Foreground="{DynamicResource CardDescriptionBrush}" HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Grid View -->
            <ScrollViewer x:Name="GalleryScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Loaded="ScrollViewer_Loaded"
                          ScrollChanged="ScrollViewer_ScrollChanged"
                          Visibility="{Binding IsGalleryEmpty, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <ItemsControl x:Name="GalleryItemsControl"
                              ItemsSource="{Binding Photos}"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              VirtualizingPanel.CacheLength="1,1"
                              VirtualizingPanel.CacheLengthUnit="Page"
                              VirtualizingPanel.ScrollUnit="Pixel">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" ItemWidth="180" ItemHeight="218" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <views:PhotoTileControl DataContext="{Binding}"
                                                    MouseDoubleClick="OnPhotoTileDoubleClick" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Timeline View -->
            <ScrollViewer x:Name="TimelineScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding IsTimelineView, Converter={StaticResource BoolToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding TimelineGroups}"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              VirtualizingPanel.CacheLength="2,2"
                              VirtualizingPanel.CacheLengthUnit="Page"
                              VirtualizingPanel.ScrollUnit="Pixel">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:TimelineYearGroup}">
                            <Border Margin="16,8" Background="{DynamicResource CardBackground}"
                                    CornerRadius="10" Padding="16">
                                <StackPanel>
                                    <Button Command="{Binding DataContext.ToggleYearCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SecondaryButton}"
                                            HorizontalAlignment="Left" Padding="12,8" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#x25B6;" FontSize="12" VerticalAlignment="Center"
                                                       Margin="0,0,8,0" RenderTransformOrigin="0.5,0.5">
                                                <TextBlock.RenderTransform>
                                                    <RotateTransform Angle="{Binding IsExpanded, Converter={StaticResource YearExpandAngleConverter}}" />
                                                </TextBlock.RenderTransform>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Year}" FontSize="20" FontWeight="Bold"
                                                       Foreground="{DynamicResource TitleTextBrush}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                            <TextBlock Text="{Binding PhotoCount, StringFormat='{}{0} photos'}"
                                                       FontSize="13" Foreground="{DynamicResource CardDescriptionBrush}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>

                                    <ItemsControl ItemsSource="{Binding Months}" Margin="24,0,0,0"
                                                  Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:TimelineMonthGroup}">
                                                <Border Margin="12,4" Background="{DynamicResource CardBackground}"
                                                        CornerRadius="8" Padding="12">
                                                    <StackPanel>
                                                        <Button Command="{Binding DataContext.ToggleMonthCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource SecondaryButton}"
                                                                HorizontalAlignment="Left" Padding="10,6" Margin="0,0,0,6">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="&#x25B6;" FontSize="10" VerticalAlignment="Center"
                                                                           Margin="0,0,6,0" RenderTransformOrigin="0.5,0.5">
                                                                    <TextBlock.RenderTransform>
                                                                        <RotateTransform Angle="{Binding IsExpanded, Converter={StaticResource YearExpandAngleConverter}}" />
                                                                    </TextBlock.RenderTransform>
                                                                </TextBlock>
                                                                <TextBlock Text="{Binding DisplayName}" FontSize="15" FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource TitleTextBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                                                <TextBlock Text="{Binding PhotoCount, StringFormat='{}{0} photos'}"
                                                                           FontSize="12" Foreground="{DynamicResource CardDescriptionBrush}" VerticalAlignment="Center" />
                                                            </StackPanel>
                                                        </Button>

                                                        <ItemsControl ItemsSource="{Binding Days}" Margin="20,0,0,0"
                                                                      Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate DataType="{x:Type models:TimelineDayGroup}">
                                                                    <Border Margin="8,2" Background="{DynamicResource CardBackground}"
                                                                            CornerRadius="6" Padding="10">
                                                                        <StackPanel>
                                                                            <Button Command="{Binding DataContext.ToggleDayCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                    CommandParameter="{Binding}"
                                                                                    Style="{StaticResource SecondaryButton}"
                                                                                    HorizontalAlignment="Left" Padding="8,4" Margin="0,0,0,4">
                                                                                <StackPanel Orientation="Horizontal">
                                                                                    <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"
                                                                                               Foreground="{DynamicResource TitleTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                                                    <TextBlock Text="{Binding PhotoCount, StringFormat='{}{0} photos'}"
                                                                                               FontSize="11" Foreground="{DynamicResource CardDescriptionBrush}" VerticalAlignment="Center" />
                                                                                </StackPanel>
                                                                            </Button>

                                                                            <ItemsControl ItemsSource="{Binding Photos}" Margin="16,0,0,4"
                                                                                          Visibility="{Binding IsLoaded, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                                <ItemsControl.ItemsPanel>
                                                                                    <ItemsPanelTemplate>
                                                                                        <WrapPanel Orientation="Horizontal" ItemWidth="120" ItemHeight="140" />
                                                                                    </ItemsPanelTemplate>
                                                                                </ItemsControl.ItemsPanel>
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate DataType="{x:Type models:GalleryPhoto}">
                                                                                        <views:PhotoTileControl DataContext="{Binding}"
                                                                                                                MouseDoubleClick="OnTimelinePhotoDoubleClick"
                                                                                                                Width="120" Height="140" />
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Loading Overlay -->
            <Border x:Name="LoadingOverlay" Background="#80000000" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="&#x1F4F7;" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12" />
                    <TextBlock Text="Loading your gallery..." FontSize="16" FontWeight="SemiBold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,6" />
                    <TextBlock Text="{Binding LoadingElapsed}" FontSize="14"
                               Foreground="#CCFFFFFF" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{DynamicResource GalleryStatusBarBackground}"
                BorderBrush="{DynamicResource GalleryStatusBarBorder}" BorderThickness="0,1,0,0" Padding="20,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" FontSize="11" Foreground="{DynamicResource GalleryStatusText}"
                           Text="{Binding LoadedCount, StringFormat='Loaded: {0}'}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" FontSize="11" Foreground="{DynamicResource GalleryStatusText}"
                           Text="{Binding TotalCount, StringFormat='Total: {0}'}" VerticalAlignment="Center" Margin="20,0,0,0" />
                <TextBlock Grid.Column="2" FontSize="11" Foreground="{DynamicResource GalleryStatusText}"
                           Text="{Binding MemoryEstimate, StringFormat='Memory: {0}'}" VerticalAlignment="Center" Margin="20,0,0,0" />
                <TextBlock Grid.Column="4" FontSize="11" Foreground="{DynamicResource GalleryStatusText}"
                           Text="{Binding LastQueryLatencyMs, StringFormat='Query: {0:F1}ms'}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="5" FontSize="11" Foreground="{DynamicResource GalleryStatusText}"
                           Text="{Binding LoadingElapsed}" VerticalAlignment="Center" Margin="20,0,0,0" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
