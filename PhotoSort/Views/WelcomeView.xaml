<UserControl x:Class="PhotoSort.Views.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{DynamicResource WindowBackground}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" ClipToBounds="True">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{DynamicResource HeaderGradientStartColor}" Offset="0" />
                    <GradientStop Color="{DynamicResource HeaderGradientEndColor}" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid Margin="40,48,40,52">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Grid.Row="1"
                           Text="{Binding Title}"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{DynamicResource HeaderTextBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10" />

                <!-- Subtitle -->
                <TextBlock Grid.Row="2"
                           Text="{Binding Subtitle}"
                           FontSize="15"
                           Foreground="#CCFFFFFF"
                           TextWrapping="Wrap"
                           Margin="0,0,0,28"
                           MaxWidth="640" />

                <!-- Buttons -->
                <StackPanel Grid.Row="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <Button Content="{Binding ImportButtonText}"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding ImportFolderCommand}"
                            IsEnabled="{Binding IsImporting, Converter={StaticResource InverseBoolConverter}}"
                            Margin="0,0,12,0" />
                    <Button Content="{Binding TourButtonText}"
                            Style="{StaticResource SecondaryButton}" />
                </StackPanel>

                <!-- Import Status -->
                <StackPanel Grid.Row="4"
                            Margin="0,8,0,0"
                            Visibility="{Binding ImportStatusText, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding ImportStageText}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource CardDescriptionBrush}"
                               Margin="0,0,0,6" />
                    <Border CornerRadius="12"
                            ClipToBounds="True"
                            Height="24">
                        <Grid>
                            <Border Background="{DynamicResource GallerySkeletonBrush}" />
                            <Border Background="{DynamicResource PrimaryButtonBackground}"
                                    HorizontalAlignment="Stretch"
                                    RenderTransformOrigin="0,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="{Binding ImportPercentage, Converter={StaticResource PercentageToScaleConverter}}" />
                                </Border.RenderTransform>
                            </Border>
                            <TextBlock Text="{Binding ImportPercentage, StringFormat='{}{0:F0}%'}"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <TextBlock Text="{Binding ImportStatusText}"
                               FontSize="12"
                               Foreground="{DynamicResource GalleryStatusText}"
                               Margin="0,6,0,0"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="40,36,40,40">

                <!-- Section Header -->
                <TextBlock Text="Why PhotoSort?"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TitleTextBrush}"
                           Margin="0,0,0,20" />

                <!-- Feature Cards -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Privacy First -->
                    <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <Ellipse Width="48" Height="48"
                                     Fill="{DynamicResource PrivacyIconBackground}"
                                     HorizontalAlignment="Left" />
                            <TextBlock Text="&#x1F512;" FontSize="22"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,-36,0,24"
                                       Foreground="{DynamicResource PrivacyIconForeground}" />
                            <TextBlock Text="Privacy First"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource CardTitleBrush}"
                                       Margin="0,0,0,6" />
                            <TextBlock Text="Your photos never leave your device. Everything is processed locally with zero cloud dependency."
                                       FontSize="13"
                                       Foreground="{DynamicResource CardDescriptionBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- Local Processing -->
                    <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <Ellipse Width="48" Height="48"
                                     Fill="{DynamicResource LocalIconBackground}"
                                     HorizontalAlignment="Left" />
                            <TextBlock Text="&#x2699;" FontSize="22"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,-36,0,24"
                                       Foreground="{DynamicResource LocalIconForeground}" />
                            <TextBlock Text="Local Processing"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource CardTitleBrush}"
                                       Margin="0,0,0,6" />
                            <TextBlock Text="Lightning-fast sorting and categorization powered by your own hardware — no internet required."
                                       FontSize="13"
                                       Foreground="{DynamicResource CardDescriptionBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- Secure Storage -->
                    <Border Grid.Column="4" Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <Ellipse Width="48" Height="48"
                                     Fill="{DynamicResource SecureIconBackground}"
                                     HorizontalAlignment="Left" />
                            <TextBlock Text="&#x1F510;" FontSize="22"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,-36,0,24"
                                       Foreground="{DynamicResource SecureIconForeground}" />
                            <TextBlock Text="Secure Storage"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource CardTitleBrush}"
                                       Margin="0,0,0,6" />
                            <TextBlock Text="Organized collections are saved securely on disk. Your memories stay yours — always."
                                       FontSize="13"
                                       Foreground="{DynamicResource CardDescriptionBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Imported Folders Section -->
                <Border Style="{StaticResource CardBorder}"
                        Margin="0,32,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,16">
                            <TextBlock Text="Imported Folders"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TitleTextBrush}"
                                       VerticalAlignment="Center" />
                            <Border Background="{DynamicResource PrivacyIconBackground}"
                                    CornerRadius="10"
                                    Padding="10,3"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding ImportedFolderCount}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrivacyIconForeground}" />
                            </Border>
                        </StackPanel>

                        <!-- Empty State -->
                        <Border Grid.Row="1"
                                CornerRadius="8"
                                Padding="32,28"
                                Margin="0,0,0,4"
                                Background="{DynamicResource CardHoverBackground}"
                                Visibility="{Binding ImportedFolderCount, Converter={StaticResource ZeroToVisibleConverter}}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="&#x1F4C1;"
                                           FontSize="28"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,10" />
                                <TextBlock Text="No folders imported yet"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource CardTitleBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,4" />
                                <TextBlock Text="Click &quot;Import Folder&quot; above to get started"
                                           FontSize="12"
                                           Foreground="{DynamicResource CardDescriptionBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Folder List -->
                        <Border Grid.Row="2"
                                CornerRadius="8"
                                Background="{DynamicResource CardHoverBackground}"
                                Visibility="{Binding ImportedFolderCount, Converter={StaticResource NonZeroToVisibleConverter}}">
                            <ListView x:Name="FoldersListView"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      Foreground="{DynamicResource CardTitleBrush}"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      Padding="4">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,0,0,2" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Folder Icon -->
                                            <TextBlock Text="&#x1F4C2;"
                                                       FontSize="20"
                                                       Grid.Column="0"
                                                       VerticalAlignment="Center" />

                                            <!-- Folder Info -->
                                            <StackPanel Grid.Column="2"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource CardTitleBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource CardDescriptionBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>

                                            <!-- Remove Button -->
                                            <Button Grid.Column="3"
                                                    Command="{Binding DataContext.RemoveFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Cursor="Hand"
                                                    ToolTip="Remove folder"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Padding="8,4"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="&#x2715;"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource CardDescriptionBrush}" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
