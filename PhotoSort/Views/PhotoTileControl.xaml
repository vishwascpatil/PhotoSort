<UserControl x:Class="PhotoSort.Views.PhotoTileControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="220" d:DesignWidth="200">

    <Border x:Name="TileBorder"
            CornerRadius="10"
            Background="{DynamicResource GalleryTileBackground}"
            BorderBrush="{DynamicResource GalleryTileBorder}"
            BorderThickness="1"
            Margin="4"
            ClipToBounds="True"
            Cursor="Hand">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Photo Placeholder Area -->
            <Grid Grid.Row="0"
                  Background="{DynamicResource GalleryPlaceholderBackground}">
                <!-- Static Thumbnail Image (always shown, poster frame for videos) -->
                <Image x:Name="ThumbnailImage"
                       Source="{Binding EffectiveSmallThumbnail, Converter={StaticResource ThumbnailToBitmapConverter}}"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Stretch="UniformToFill"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="{Binding EffectiveSmallThumbnail, Converter={StaticResource NullOrEmptyToVisibilityConverter}}" />

                <!-- Auto-play Video (starts collapsed, shown when clip is ready) -->
                <MediaElement x:Name="VideoPlayer"
                              Visibility="Collapsed"
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Stop"
                              IsMuted="True"
                              Stretch="UniformToFill"
                              MediaOpened="VideoPlayer_MediaOpened"
                              MediaEnded="VideoPlayer_MediaEnded"
                              MediaFailed="VideoPlayer_MediaFailed" />

                <!-- Video Badge -->
                <Border HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="8,8,0,0"
                        Background="#99000000"
                        CornerRadius="4"
                        Padding="5,2"
                        Visibility="{Binding IsVideo, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x25B6;"
                                   FontSize="10"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,0,3,0" />
                        <TextBlock Text="VIDEO"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Favorite Indicator -->
                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,8,8,0"
                        Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Ellipse Width="10" Height="10"
                             Fill="{DynamicResource GalleryFavoriteBrush}" />
                </Border>
            </Grid>

            <!-- Info Bar -->
            <Border Grid.Row="1"
                    Background="{DynamicResource GalleryTileBackground}"
                    Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding FileName}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource GalleryTileFileName}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="140" />
                        <TextBlock Text="{Binding DisplayDate}"
                                   FontSize="11"
                                   Foreground="{DynamicResource GalleryTileDate}"
                                   Margin="0,2,0,0"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="{Binding DisplaySize}"
                               FontSize="10"
                               Foreground="{DynamicResource GalleryTileDate}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
