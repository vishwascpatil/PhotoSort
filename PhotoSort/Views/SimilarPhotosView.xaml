<UserControl x:Class="PhotoSort.Views.SimilarPhotosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:PhotoSort.Models"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{DynamicResource WindowBackground}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource GalleryStatusBarBorder}"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="&#x1F5BC;"
                               FontSize="20"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <TextBlock Text="Similar Photos"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TitleTextBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Button Command="{Binding StartScanCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Padding="16,8"
                            FontSize="13"
                            Visibility="{Binding IsRunning, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x25B6;" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Start Scan" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding PauseScanCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="16,8"
                            FontSize="13"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}"
                            IsEnabled="{Binding IsPaused, Converter={StaticResource InverseBoolConverter}}"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x23F8;" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Pause" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ResumeScanCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="16,8"
                            FontSize="13"
                            Visibility="{Binding IsPaused, Converter={StaticResource BoolToVisibilityConverter}}"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x25B6;" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Resume" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding CancelScanCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="16,8"
                            FontSize="13"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2715;" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Cancel" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <!-- Left: Results List -->
            <Grid Grid.Column="0">
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="{Binding HasResults, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <TextBlock Text="&#x1F5BC;"
                               FontSize="48"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16" />
                    <TextBlock Text="No similar photos found yet"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TitleTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8" />
                    <TextBlock Text="Click 'Start Scan' to detect visually similar photos"
                               FontSize="14"
                               Foreground="{DynamicResource CardDescriptionBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding SimilarGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:SimilarPhotoGroup}">
                                <Border Margin="8,4"
                                        Background="{DynamicResource CardBackground}"
                                        CornerRadius="8"
                                        Padding="12"
                                        BorderBrush="{DynamicResource GalleryTileBorder}"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="OnGroupClick">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Thumbnail -->
                                        <Border Grid.Column="0"
                                                Width="50"
                                                Height="50"
                                                CornerRadius="6"
                                                ClipToBounds="True"
                                                Background="{DynamicResource GalleryPlaceholderBackground}"
                                                Margin="0,0,12,0">
                                            <Image Source="{Binding BestPhoto.ThumbnailSmallPath, Converter={StaticResource ThumbnailToBitmapConverter}}"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   Stretch="UniformToFill"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                        </Border>

                                        <!-- Group Info -->
                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding GroupSize}"
                                                           FontSize="16"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource TitleTextBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,6,0" />
                                                <TextBlock Text="photos"
                                                           FontSize="13"
                                                           Foreground="{DynamicResource CardDescriptionBrush}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,4,0,0">
                                                <Border Background="{DynamicResource GalleryFavoriteBrush}"
                                                        CornerRadius="4"
                                                        Padding="6,2"
                                                        Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding DisplayLevel}"
                                                               FontSize="10"
                                                               FontWeight="Bold"
                                                               Foreground="White" />
                                                </Border>
                                                <TextBlock Text="{Binding DisplaySavings, StringFormat='Save: {0}', Mode=OneWay}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource GalleryMetricText}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Arrow -->
                                        <TextBlock Grid.Column="2"
                                                   Text="&#x276E;"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource GalleryStatusText}"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Progress Overlay -->
                <Border Background="#80000000"
                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <Border Background="{DynamicResource CardBackground}"
                                CornerRadius="12"
                                Padding="32"
                                MinWidth="320">
                            <StackPanel>
                                <TextBlock Text="{Binding CurrentProgress.PhaseDisplay}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TitleTextBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,16" />

                                <Border Background="{DynamicResource GallerySkeletonBrush}"
                                        CornerRadius="4"
                                        Height="8"
                                        Margin="0,0,0,12">
                                    <Border Background="{DynamicResource PrimaryButtonBackground}"
                                            CornerRadius="4"
                                            HorizontalAlignment="Left"
                                            Width="{Binding CurrentProgress.ProgressPercent, Mode=OneWay}" />
                                </Border>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Thumbnails"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource GalleryStatusText}" />
                                        <TextBlock Text="{Binding CurrentProgress.ThumbnailsAvailable, Mode=OneWay}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TitleTextBrush}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Hashes Generated"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource GalleryStatusText}" />
                                        <TextBlock Text="{Binding CurrentProgress.HashesGenerated, Mode=OneWay}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TitleTextBrush}" />
                                    </StackPanel>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Photos Compared"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource GalleryStatusText}" />
                                        <TextBlock Text="{Binding CurrentProgress.PhotosCompared, Mode=OneWay}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TitleTextBrush}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Groups Found"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource GalleryStatusText}" />
                                        <TextBlock Text="{Binding CurrentProgress.GroupsFound, Mode=OneWay}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource GalleryMetricText}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Right: Details Panel -->
            <Border Grid.Column="1"
                    Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource GalleryStatusBarBorder}"
                    BorderThickness="1,0,0,0"
                    Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Details Header -->
                    <Border Grid.Row="0"
                            Padding="16,12"
                            BorderBrush="{DynamicResource GalleryStatusBarBorder}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Group Details"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TitleTextBrush}" />
                                <TextBlock Text="{Binding StatusMessage}"
                                           FontSize="11"
                                           Foreground="{DynamicResource GalleryStatusText}"
                                           Margin="0,4,0,0"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                Margin="16,12"
                                Visibility="{Binding SelectedGroup, Converter={StaticResource NullToVisibilityConverter}}">
                        <Button Command="{Binding KeepBestCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Padding="12,6"
                                FontSize="11"
                                Margin="0,0,8,0">
                            <TextBlock Text="Keep Best Only" />
                        </Button>
                        <Button Command="{Binding IgnoreGroupCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Padding="12,6"
                                FontSize="11">
                            <TextBlock Text="Ignore Group" />
                        </Button>
                    </StackPanel>

                    <!-- Photos Grid -->
                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding SelectedGroupPhotos}"
                                      Margin="16,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:SimilarPhotoItem}">
                                    <Border Margin="0,0,0,8"
                                            Background="{DynamicResource CardBackground}"
                                            CornerRadius="8"
                                            Padding="10"
                                            BorderBrush="{DynamicResource GalleryTileBorder}"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Thumbnail -->
                                            <Border Grid.Column="0"
                                                    Width="45"
                                                    Height="45"
                                                    CornerRadius="4"
                                                    ClipToBounds="True"
                                                    Background="{DynamicResource GalleryPlaceholderBackground}"
                                                    Margin="0,0,10,0">
                                                <Image Source="{Binding ThumbnailSmallPath, Converter={StaticResource ThumbnailToBitmapConverter}}"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       Stretch="UniformToFill"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                            </Border>

                                            <!-- Photo Info -->
                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FileName}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TitleTextBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock FontSize="10"
                                                           Foreground="{DynamicResource GalleryStatusText}"
                                                           Margin="0,2,0,0">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0}  |  {1}">
                                                            <Binding Path="DisplayDate" Mode="OneWay" />
                                                            <Binding Path="DisplaySize" Mode="OneWay" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                                <TextBlock Text="{Binding DisplayDistance}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource GalleryFavoriteBrush}"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>

                                            <!-- Actions -->
                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Border Visibility="{Binding IsBest, Converter={StaticResource BoolToVisibilityConverter}}"
                                                        Background="{DynamicResource PrimaryButtonBackground}"
                                                        CornerRadius="4"
                                                        Padding="6,3">
                                                    <TextBlock Text="BEST"
                                                               FontSize="9"
                                                               FontWeight="Bold"
                                                               Foreground="White" />
                                                </Border>
                                                <Button Command="{Binding DataContext.DeletePhotoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Padding="6,4"
                                                        FontSize="10"
                                                        Margin="8,0,0,0"
                                                        Visibility="{Binding IsBest, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                                    <TextBlock Text="Delete"
                                                               Foreground="{DynamicResource GalleryFavoriteBrush}" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Empty State -->
                    <StackPanel Grid.Row="2"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Visibility="{Binding SelectedGroup, Converter={StaticResource NullToVisibilityConverter}}">
                        <TextBlock Text="Select a group"
                                   FontSize="14"
                                   Foreground="{DynamicResource GalleryStatusText}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource GalleryStatusBarBackground}"
                BorderBrush="{DynamicResource GalleryStatusBarBorder}"
                BorderThickness="0,1,0,0"
                Padding="20,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding SimilarGroups.Count, StringFormat='Groups: {0}', Mode=OneWay}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource GalleryMetricText}"
                           VerticalAlignment="Center" />

                <TextBlock Grid.Column="1"
                           Text="{Binding CurrentProgress.HashesGenerated, StringFormat='Photos: {0}', Mode=OneWay}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource GalleryMetricText}"
                           VerticalAlignment="Center"
                           Margin="24,0,0,0" />

                <TextBlock Grid.Column="2"
                           Text="{Binding CurrentProgress.DisplayReclaimable, StringFormat='Savings: {0}', Mode=OneWay}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource GalleryMetricText}"
                           VerticalAlignment="Center"
                           Margin="24,0,0,0" />

                <TextBlock Grid.Column="4"
                           Text="{Binding StatusMessage}"
                           FontSize="12"
                           Foreground="{DynamicResource GalleryStatusText}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="300"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
